// Data types shared between Slint UI and Rust

export enum ItemType {
    text,
    select,
    password,
    toggle,
    separator,
    action,
    readonly,
    warning,
    // Visual section divider — small uppercase label, no card. Skipped in
    // the review screen because the step-level header already groups things.
    section-header,
    // Header of an inline radio group: same visual as section-header but
    // semantically *bound* to the RadioOption rows that immediately follow.
    // The review screen collapses (radio-header + N radio-options) into a
    // single readonly summary row.
    radio-header,
    radio-option,
}

export struct ConfigItem {
    key: string,
    label: string,
    value: string,
    item-type: ItemType,
    // True if this row is the first field row inside its section (i.e. the
    // previous item in the list is a SectionHeader). Used by ConfigItemRow
    // to round only the top corners of the connected section card.
    is-first-in-section: bool,
    // True if this row is the last field row inside its section (i.e. the
    // next item in the list is a SectionHeader, Separator, or end of list).
    // Used to round bottom corners and skip the trailing hairline divider.
    is-last-in-section: bool,
}

export struct SelectOption {
    text: string,
}

// One row in MultiSelectPopup. `text` is the package name (or whatever is
// being multi-selected); `description` is an optional human-readable hint
// shown to the right of the label. `checked` is the user's current toggle
// state.
export struct MultiSelectOption {
    text: string,
    description: string,
    checked: bool,
}

export struct UserEntry {
    username: string,
    has-sudo: bool,
}

export struct PackageEntry {
    name: string,
    repo: string,
}

export struct PackageSearchResult {
    name: string,
    description: string,
    repo: string,
}

export struct LogMessage {
    text: string,
    level: int,
}

export struct DownloadInfo {
    filename: string,
    pct: int,
    speed: string,
    state: int,
}

// ── WiFi types ──────────────────────────────────────────────────────────────

// Security mode of a discovered or known network. Mirrors the Rust
// `core::system::wifi::Security` enum one-for-one; the Rust→Slint
// controller translates with a straightforward match.
export enum WifiSecurity {
    open,
    wep,
    psk,
    // 802.1x enterprise — shown in the scan list but connect is disabled.
    enterprise,
}

// High-level phase the wifi popup is in. Controller drives transitions;
// the popup component picks different content per phase.
//
//   idle       — popup just opened or no action in progress
//   scanning   — scan in progress, show spinner + status
//   picking    — scan finished, user picks from the list
//   auth       — user is typing a password for a secured network
//   connecting — Network.Connect() in flight
//   verifying  — connect returned success, waiting for DHCP / internet
//   connected  — fully online, popup shows success and auto-dismisses
//   error      — something failed, show error text + retry actions
export enum WifiPhase {
    idle,
    scanning,
    picking,
    auth,
    connecting,
    verifying,
    connected,
    error,
}

// One row in the wifi popup's network list. Rebuilt by the Rust
// controller after every scan.
export struct WifiNetworkUi {
    ssid: string,
    // Normalized 0-100.
    signal-percent: int,
    security: WifiSecurity,
    // True if iwd has a saved profile — the UI skips the password prompt
    // and shows a "Known" badge.
    known: bool,
}

