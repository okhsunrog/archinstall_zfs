// Welcome screen — three system-check status cards (network / UEFI / ZFS)
// and a Get-Started button gated by all checks passing. Absolutely-
// positioned connectivity widget in the bottom-right corner opens the
// WiFi management popup (if any wifi hardware is present).

import { Theme } from "../styling.slint";
import { WelcomeState } from "../state/welcome-state.slint";
import { WizardState } from "../state/wizard-state.slint";
import { WifiState } from "../state/wifi-state.slint";
import { Icon } from "../components/icon.slint";
import { SignalBars } from "../components/signal-bars.slint";

export component WelcomeView inherits Rectangle {
    background: Theme.c.base;

    // ── Bottom-right connectivity widget ───────────────────────────────
    // Absolutely-positioned pill in the corner — canonical spot for a
    // connectivity indicator. Gated on `WifiState.has-hardware` so it
    // stays hidden on machines that genuinely have no wireless NIC;
    // when hardware exists but iwd isn't running, the widget still
    // shows and explains the situation on click (via the popup's
    // iwd-unavailable path, which just leaves the network list empty).
    if WifiState.has-hardware: Rectangle {
        x: root.width - self.width - 16px;
        y: root.height - self.height - 16px;
        width: 172px;
        height: 40px;
        background: corner-ta.has-hover ? Theme.c.surface1 : Theme.c.surface0;
        border-radius: 20px;
        border-width: 1px;
        border-color: Theme.c.surface1;

        corner-ta := TouchArea {
            clicked => { WifiState.open(); }
            mouse-cursor: pointer;
        }

        HorizontalLayout {
            padding-left: 12px;
            padding-right: 14px;
            spacing: 8px;

            // Icon — colored by state: green for connected wifi, blue
            // for "iwd running but not associated", muted for "iwd not
            // running or no connection at all".
            Icon {
                source: WifiState.current-ssid != ""
                    ? @image-url("../../assets/icons/wifi.svg")
                    : @image-url("../../assets/icons/wifi-off.svg");
                size: 18px;
                tint: WifiState.current-ssid != "" ? Theme.c.green
                    : WifiState.iwd-running ? Theme.c.blue
                    : Theme.c.overlay0;
            }

            // Label — SSID when connected, "Not connected" otherwise,
            // "WiFi unavailable" when iwd isn't running at all.
            Text {
                text: WifiState.current-ssid != ""
                    ? WifiState.current-ssid
                    : (WifiState.iwd-running ? "Not connected" : "WiFi unavailable");
                color: WifiState.current-ssid != ""
                    ? Theme.c.text : Theme.c.subtext0;
                font-size: Theme.font-sm;
                vertical-alignment: center;
                horizontal-stretch: 1;
                overflow: elide;
            }
        }
    }

    VerticalLayout {
        alignment: center;
        spacing: 0px;

        HorizontalLayout {
            alignment: center;

            VerticalLayout {
                width: min(500px, root.width - 60px);
                spacing: 24px;
                alignment: center;

                // Title
                VerticalLayout {
                    spacing: 8px;

                    Text {
                        text: "archinstall-zfs";
                        color: Theme.c.blue;
                        font-size: 36px;
                        font-weight: FontWeight.bold;
                        horizontal-alignment: center;
                    }

                    Text {
                        text: "Arch Linux installer with ZFS root";
                        color: Theme.c.subtext0;
                        font-size: 16px;
                        horizontal-alignment: center;
                    }
                }

                // Status cards
                VerticalLayout {
                    spacing: 8px;

                    // Network status
                    Rectangle {
                        height: 48px;
                        background: Theme.c.surface0;
                        border-radius: 10px;

                        HorizontalLayout {
                            padding-left: 16px;
                            padding-right: 12px;
                            spacing: 12px;

                            Text {
                                text: WelcomeState.net-ok ? "\u{2713}" : "\u{2717}";
                                color: WelcomeState.net-ok ? Theme.c.green : Theme.c.red;
                                font-size: 18px;
                                vertical-alignment: center;
                                width: 24px;
                            }

                            Text {
                                text: "Internet connection";
                                color: Theme.c.text;
                                font-size: 14px;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                            }

                            Text {
                                text: WelcomeState.net-ok ? "Connected" : "Not connected";
                                color: WelcomeState.net-ok ? Theme.c.green : Theme.c.overlay0;
                                font-size: 13px;
                                vertical-alignment: center;
                            }

                            if !WelcomeState.net-ok: Rectangle {
                                width: 90px;
                                height: 30px;
                                background: check-net-ta.has-hover ? Theme.c.surface1 : Theme.c.mantle;
                                border-radius: 6px;

                                check-net-ta := TouchArea {
                                    clicked => { WelcomeState.check-internet(); }
                                }

                                Text {
                                    text: "Check again";
                                    color: Theme.c.blue;
                                    font-size: 12px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }

                    // UEFI status
                    Rectangle {
                        height: 48px;
                        background: Theme.c.surface0;
                        border-radius: 10px;

                        HorizontalLayout {
                            padding-left: 16px;
                            padding-right: 16px;
                            spacing: 12px;

                            Text {
                                text: WelcomeState.uefi-ok ? "\u{2713}" : "\u{2717}";
                                color: WelcomeState.uefi-ok ? Theme.c.green : Theme.c.red;
                                font-size: 18px;
                                vertical-alignment: center;
                                width: 24px;
                            }

                            Text {
                                text: "UEFI boot mode";
                                color: Theme.c.text;
                                font-size: 14px;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                            }

                            Text {
                                text: WelcomeState.uefi-ok ? "Detected" : "Not detected (required)";
                                color: WelcomeState.uefi-ok ? Theme.c.green : Theme.c.red;
                                font-size: 13px;
                                vertical-alignment: center;
                            }
                        }
                    }

                    // ZFS status
                    zfs-card := Rectangle {
                        height: 48px;
                        background: Theme.c.surface0;
                        border-radius: 10px;

                        VerticalLayout {
                            padding: 0px;
                            spacing: 0px;

                            HorizontalLayout {
                                height: 48px;
                                padding-left: 16px;
                                padding-right: 16px;
                                spacing: 12px;

                                zfs-icon := Text {
                                    text: "\u{2717}";
                                    color: Theme.c.overlay0;
                                    font-size: 18px;
                                    vertical-alignment: center;
                                    width: 24px;
                                }

                                Text {
                                    text: "ZFS support";
                                    color: Theme.c.text;
                                    font-size: 14px;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                }

                                zfs-status := Text {
                                    text: "Waiting for network...";
                                    color: Theme.c.overlay0;
                                    font-size: 13px;
                                    vertical-alignment: center;
                                }
                            }

                            if WelcomeState.zfs-installing: Rectangle {
                                height: 6px;
                                x: 16px;
                                width: parent.width - 32px;
                                background: Theme.c.mantle;
                                border-radius: 3px;
                                clip: true;

                                Rectangle {
                                    x: 0; y: 0;
                                    height: parent.height;
                                    width: parent.width * WelcomeState.zfs-install-pct / 100;
                                    background: Theme.c.blue;
                                    border-radius: 3px;
                                }
                            }

                            if WelcomeState.zfs-installing: Rectangle {
                                height: 12px;
                            }
                        }

                        // Three-way state: idle (base) → installing → ready.
                        // Last match wins, so `ready` overrides `installing` if
                        // both somehow match.
                        states [
                            installing when WelcomeState.zfs-installing: {
                                zfs-card.height: 72px;
                                zfs-icon.text: "\u{21bb}";
                                zfs-icon.color: Theme.c.blue;
                                zfs-status.text: WelcomeState.zfs-install-status;
                                zfs-status.color: Theme.c.blue;
                            }
                            ready when WelcomeState.zfs-ok: {
                                zfs-icon.text: "\u{2713}";
                                zfs-icon.color: Theme.c.green;
                                zfs-status.text: "Ready";
                                zfs-status.color: Theme.c.green;
                            }
                        ]
                    }
                }

                // Start button
                HorizontalLayout {
                    alignment: center;

                    start-button := Rectangle {
                        width: 160px;
                        height: 44px;
                        background: Theme.c.surface1;
                        border-radius: 10px;

                        start-ta := TouchArea {
                            enabled: WelcomeState.all-checks-ok;
                            mouse-cursor: self.enabled ? pointer : default;
                            clicked => { WizardState.go-to(1); }
                        }

                        start-text := Text {
                            text: "Get Started \u{2192}";
                            color: Theme.c.overlay0;
                            font-size: 15px;
                            font-weight: FontWeight.semi-bold;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }

                        states [
                            ready when WelcomeState.all-checks-ok: {
                                start-button.background: Theme.c.blue;
                                start-text.color: Theme.c.base;
                            }
                            ready-hover when WelcomeState.all-checks-ok && start-ta.has-hover: {
                                start-button.background: Theme.c.sky;
                                start-text.color: Theme.c.base;
                            }
                        ]
                    }
                }

                Text {
                    text: "v" + WelcomeState.app-version;
                    color: Theme.c.overlay0;
                    font-size: 11px;
                    horizontal-alignment: center;
                }
            }
        }
    }
}
