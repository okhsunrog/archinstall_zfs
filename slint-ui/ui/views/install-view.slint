// Install progress screen — scrolling log + a progress card with the current
// phase, optional package-download details, and completion actions.

import { ListView } from "std-widgets.slint";
import { Theme } from "../styling.slint";
import { InstallState } from "../state/install-state.slint";
import { StyledButton } from "../components/styled-button.slint";

export component InstallView inherits VerticalLayout {
    callback quit-requested();
    callback reboot-requested();

    padding: 12px;
    spacing: 8px;

    // Log area (fills available space)
    log-view := ListView {
        for msg[index] in InstallState.log-messages: Rectangle {
            height: msg-text.preferred-height + 4px;

            msg-text := Text {
                text: msg.text;
                color: msg.level == 4 ? Theme.c.red
                     : msg.level == 3 ? Theme.c.yellow
                     : msg.level == 2 ? Theme.c.green
                     : msg.level == 1 ? Theme.c.blue
                     : Theme.c.overlay0;
                font-family: "monospace";
                font-size: 12px;
                x: 8px;
                width: parent.width - 16px;
                wrap: word-wrap;
                vertical-alignment: center;
            }
        }
    }

    // Auto-pin to the bottom whenever a new log line lands. Computed from
    // the live viewport height so it stays correct when the log overflows
    // the visible area; clamped to 0 so a short log doesn't push above
    // the top.
    property <int> scroll-trigger: InstallState.log-messages.length;
    changed scroll-trigger => {
        log-view.viewport-y = -max(0px, log-view.viewport-height - log-view.height);
    }

    // Progress card (always visible during install)
    Rectangle {
        height: InstallState.download-active ? 180px
            : InstallState.state >= 2 ? 104px
            : 80px;
        background: Theme.c.surface0;
        border-radius: 10px;

        VerticalLayout {
            padding: 14px;
            spacing: 8px;

            // Global phase status
            HorizontalLayout {
                spacing: 10px;

                Text {
                    text: InstallState.state == 2 ? "\u{2713} Complete"
                        : InstallState.state == 3 ? "\u{2717} Failed"
                        : InstallState.phase-label;
                    color: InstallState.state == 2 ? Theme.c.green
                        : InstallState.state == 3 ? Theme.c.red
                        : Theme.c.text;
                    font-size: 14px;
                    font-weight: FontWeight.semi-bold;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }

                Text {
                    text: InstallState.state >= 2 ? ""
                        : InstallState.phase + " / " + InstallState.total-phases;
                    color: Theme.c.overlay0;
                    font-size: 13px;
                    vertical-alignment: center;
                }
            }

            // Global progress bar
            if InstallState.state == 1: Rectangle {
                height: 8px;
                background: Theme.c.mantle;
                border-radius: 4px;
                clip: true;

                Rectangle {
                    x: 0; y: 0;
                    height: parent.height;
                    width: parent.width * InstallState.phase / InstallState.total-phases;
                    background: Theme.c.blue;
                    border-radius: 4px;
                }
            }

            // Package progress (download or install)
            if InstallState.download-active: VerticalLayout {
                spacing: 6px;

                HorizontalLayout {
                    Text {
                        text: InstallState.download-status;
                        color: Theme.c.teal;
                        font-size: 12px;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                    }

                    Text {
                        text: InstallState.download-pct + "%";
                        color: Theme.c.teal;
                        font-size: 12px;
                        font-weight: FontWeight.semi-bold;
                        vertical-alignment: center;
                    }
                }

                Rectangle {
                    height: 6px;
                    background: Theme.c.mantle;
                    border-radius: 3px;
                    clip: true;

                    Rectangle {
                        x: 0; y: 0;
                        height: parent.height;
                        width: parent.width * InstallState.download-pct / 100;
                        background: Theme.c.teal;
                        border-radius: 3px;
                    }
                }

                ListView {
                    for dl[index] in InstallState.download-items: Rectangle {
                        height: 18px;

                        HorizontalLayout {
                            padding-left: 4px;
                            padding-right: 4px;
                            spacing: 8px;

                            Text {
                                text: dl.filename;
                                color: dl.state == 1 ? Theme.c.overlay0
                                     : dl.state == 2 ? Theme.c.green
                                     : Theme.c.text;
                                font-size: 11px;
                                font-family: "monospace";
                                overflow: elide;
                                horizontal-stretch: 1;
                                vertical-alignment: center;
                            }

                            Text {
                                text: dl.state == 1 ? "verifying..."
                                     : dl.state == 2 ? "done"
                                     : dl.pct + "% " + dl.speed;
                                color: dl.state == 2 ? Theme.c.green : Theme.c.overlay0;
                                font-size: 11px;
                                font-family: "monospace";
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }

            // Completion actions
            if InstallState.state >= 2: HorizontalLayout {
                height: Theme.control-height;
                alignment: end;
                spacing: Theme.spacing-sm;

                StyledButton {
                    label: InstallState.state == 2 ? "Quit" : "Exit";
                    style: Theme.button-default;
                    clicked => { root.quit-requested(); }
                }

                if InstallState.state == 2: StyledButton {
                    label: "Reboot";
                    style: Theme.button-primary;
                    clicked => { root.reboot-requested(); }
                }
            }
        }
    }
}
