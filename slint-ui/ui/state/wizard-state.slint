// Wizard navigation state, owned by Slint.
//
// Rust seeds the global once at startup, listens to `step-changed` to know
// when to rebuild the config-items list, and may call `go-to(idx)` directly
// (e.g. to skip from welcome to step 1).

export global WizardState {
    in-out property <int> current-step: 0;
    in-out property <int> max-visited: 0;
    in property <int> total-steps: 7;

    // Static labels — kept here so the sidebar `for` loop has no Rust dependency.
    out property <[string]> step-labels: [
        "Welcome",
        "Disk",
        "ZFS",
        "System",
        "Users",
        "Desktop",
        "Review",
    ];

    // Emitted whenever current-step changes via the public functions below.
    // Rust uses this as the rebuild trigger.
    callback step-changed(int);

    public function go-to(idx: int) {
        if idx >= 0 && idx < total-steps {
            current-step = idx;
            if idx > max-visited {
                max-visited = idx;
            }
            step-changed(idx);
        }
    }

    public function next() {
        if current-step < total-steps - 1 {
            go-to(current-step + 1);
        }
    }

    public function back() {
        if current-step > 0 {
            current-step -= 1;
            step-changed(current-step);
        }
    }

    // Pure helper used by the sidebar to compute per-item visual state.
    // 0 = pending, 1 = current, 2 = visited/done.
    pure public function step-state-at(idx: int) -> int {
        if idx == current-step {
            return 1;
        }
        if idx <= max-visited {
            return 2;
        }
        return 0;
    }
}
