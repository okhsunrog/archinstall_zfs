import { Theme } from "../styling.slint";
import { FocusTouchArea } from "internal/state-layer.slint";

export component DeleteButton inherits Rectangle {
    callback clicked <=> touch-area.clicked;

    width: 28px;
    height: 28px;
    background: transparent;
    border-radius: Theme.radius-sm;
    forward-focus: touch-area;
    accessible-role: button;
    accessible-label: "Delete";
    accessible-action-default => { touch-area.clicked(); }

    icon := Text {
        text: "\u{2715}";
        color: Theme.c.overlay0;
        font-size: Theme.font-base;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch-area := FocusTouchArea {
        width: 100%;
        height: 100%;
    }

    states [
        hovered when touch-area.has-hover || touch-area.has-focus: {
            root.background: Theme.c.red;
            icon.color: Theme.c.base;
        }
    ]

    animate background { duration: 100ms; easing: ease-out; }
}
