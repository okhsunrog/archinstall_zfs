import { Theme } from "../styling.slint";
import { StateLayer, FocusTouchArea } from "internal/state-layer.slint";

export component SidebarItem inherits Rectangle {
    in property <string> label;
    in property <int> state; // 0=pending, 1=current, 2=done
    in property <int> step-index;

    callback clicked <=> touch-area.clicked;

    height: 36px;
    background: state == 1 ? Theme.c.surface0 : #00000000;
    border-radius: Theme.radius-sm;
    forward-focus: touch-area;
    accessible-role: button;
    accessible-label: root.label;
    accessible-enabled: state == 1 || state == 2;
    accessible-action-default => { touch-area.clicked(); }

    state-layer := StateLayer {
        width: 100%;
        height: 100%;
        border-radius: Theme.radius-sm;
        enabled: state == 1 || state == 2;
        pressed: touch-area.pressed;
        has-hover: touch-area.has-hover;
        has-focus: touch-area.has-focus;
    }

    HorizontalLayout {
        padding-left: Theme.spacing-md;
        spacing: Theme.spacing-sm;
        alignment: start;

        Text {
            text: state == 1 ? "\u{25b8}"
                : state == 2 ? "\u{25cf}"
                : "\u{25cb}";
            color: state == 1 ? Theme.c.blue
                 : state == 2 ? Theme.c.green
                 : Theme.c.overlay0;
            font-size: Theme.font-base;
            vertical-alignment: center;
            width: 16px;
        }

        Text {
            text: root.label;
            color: state == 1 ? Theme.c.blue
                 : state == 2 ? Theme.c.green
                 : Theme.c.overlay0;
            font-size: Theme.font-base;
            font-weight: state == 1 ? 600 : 400;
            vertical-alignment: center;
        }
    }

    touch-area := FocusTouchArea {
        width: 100%;
        height: 100%;
        enabled: state == 1 || state == 2;
    }
}
