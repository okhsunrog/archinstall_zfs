import { Theme, AnimationSettings } from "../styling.slint";

export component StyledTextInput inherits Rectangle {
    in property <string> placeholder: "";
    in-out property <string> text <=> input.text;
    in property <bool> is-password: false;
    in property <bool> enabled: true;
    in property <bool> read-only: false;
    in property <length> font-size: Theme.font-md;
    out property <bool> has-focus: input.has-focus;

    callback edited(string);
    callback accepted(string);

    public function focus-input() { input.focus(); }
    public function select-all() { input.select-all(); }
    public function clear-selection() { input.clear-selection(); }

    height: Theme.control-height;
    background: Theme.c.surface0;
    border-radius: Theme.radius-sm;
    border-color: Theme.c.surface1;
    border-width: 1px;
    clip: true;
    forward-focus: input;

    accessible-role: text-input;
    accessible-enabled: root.enabled;
    accessible-read-only: root.read-only;
    accessible-value <=> root.text;
    accessible-placeholder-text: root.placeholder;
    accessible-action-set-value(v) => {
        input.text = v;
        root.edited(v);
    }

    placeholder := Text {
        x: 8px;
        width: parent.width - 16px;
        text: (input.text == "" && input.preedit-text == "") ? root.placeholder : "";
        color: Theme.c.overlay0;
        font-size: root.font-size;
        vertical-alignment: center;
        accessible-role: none;
    }

    // Horizontal padding inside the input — keeps the first character and the
    // leftmost cursor position from sitting on the rounded border, matching
    // what std-widgets material/lineedit and vivi-ui's text-field do (they
    // wrap the TextInput in a HorizontalLayout with padding; we use explicit
    // bounds in the x/width formulas instead since we don't have a wrapper).
    property <length> input-padding: 8px;

    input := TextInput {
        property <length> computed-x: root.input-padding;
        // x is clamped to [parent.width - input-padding - width - cursor, input-padding].
        // When text fits, x = input-padding (text starts inside the padding).
        // When text overflows, computed-x is driven negative by the cursor handler
        // and x follows it (text scrolls left under the right padding).
        x: min(root.input-padding,
               max(parent.width - root.input-padding - self.width - self.text-cursor-width,
                   self.computed-x));
        // Reserve `input-padding` on both sides of the visible area.
        width: max(parent.width - 2 * root.input-padding - self.text-cursor-width,
                   self.preferred-width);
        height: 100%;
        vertical-alignment: center;
        color: Theme.c.text;
        font-size: root.font-size;
        input-type: root.is-password ? InputType.password : InputType.text;
        single-line: true;
        enabled: root.enabled;
        read-only: root.read-only;
        accessible-role: none;

        cursor-position-changed(cursor-position) => {
            if cursor-position.x + self.computed-x < root.input-padding {
                self.computed-x = -cursor-position.x + root.input-padding;
            } else if cursor-position.x + self.computed-x > parent.width - root.input-padding - self.text-cursor-width {
                self.computed-x = parent.width - cursor-position.x - root.input-padding - self.text-cursor-width;
            }
        }

        accepted => { root.accepted(self.text); }
        edited => { root.edited(self.text); }
    }

    states [
        disabled when !root.enabled: {
            root.opacity: 0.5;
        }
        focused when input.has-focus: {
            root.border-color: Theme.c.blue;
            root.border-width: 2px;
        }
    ]

    animate border-color, border-width { duration: AnimationSettings.color-duration; easing: ease-out; }
}
