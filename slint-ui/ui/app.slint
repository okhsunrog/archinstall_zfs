import { ListView, ScrollView } from "std-widgets.slint";

import { Catppuccin, Theme } from "styling.slint";
export { Catppuccin, Theme }

import { WizardState } from "state/wizard-state.slint";
export { WizardState }

import { EditingState } from "state/editing-state.slint";
export { EditingState }

import { PopupState } from "state/popup-state.slint";
export { PopupState }

import { WelcomeState } from "state/welcome-state.slint";
export { WelcomeState }

import { InstallState } from "state/install-state.slint";
export { InstallState }

import { WifiState } from "state/wifi-state.slint";
export { WifiState }

import { ItemType, ConfigItem, SelectOption, UserEntry, PackageEntry, PackageSearchResult, LogMessage, DownloadInfo, WifiSecurity, WifiPhase, WifiNetworkUi } from "types.slint";
export { ItemType, ConfigItem, SelectOption, UserEntry, PackageEntry, PackageSearchResult, LogMessage, DownloadInfo, WifiSecurity, WifiPhase, WifiNetworkUi }

import { TextInputPopup } from "popups/text-input-popup.slint";
import { SelectPopup } from "popups/select-popup.slint";
import { UserManagePopup } from "popups/user-manage-popup.slint";
import { StringListPopup } from "popups/string-list-popup.slint";
import { PackageSearchPopup } from "popups/package-search-popup.slint";
import { MultiSelectPopup } from "popups/multi-select-popup.slint";
import { WifiPopup } from "popups/wifi-popup.slint";

import { WelcomeView } from "views/welcome-view.slint";
import { WizardView } from "views/wizard-view.slint";
import { InstallView } from "views/install-view.slint";

// ── Main application ─────────────────────────────────

export component App inherits Window {
    background: Theme.c.base;
    preferred-width: 800px;
    preferred-height: 600px;
    title: "archinstall-zfs";
    forward-focus: main-focus-scope;

    // String list popup callbacks (only extra_services uses this for now)
    callback strlist-added(string);
    callback strlist-removed(int);

    // Package search popup callbacks
    callback pkg-search-changed(string);
    callback pkg-search-aur(string);
    callback pkg-added(int);
    callback pkg-removed(int);

    // Multi-select popup callbacks (profile optional packages, etc.)
    callback multi-select-toggled(string, int); // (key, index)
    callback multi-select-closed(string);       // key (so Rust can refresh)

    // Callbacks to Rust
    callback item-activated(string);
    callback select-confirmed(string, int);
    callback select-filter-changed(string, string); // (select-key, filter-text)
    callback text-confirmed(string, string);
    callback text-input-edited(string, string); // (text-input-key, current-text)
    callback toggle-activated(string);
    callback install-requested();
    callback quit-requested();
    callback user-added(string, string, bool); // username, password, sudo
    callback user-removed(int);
    callback user-sudo-toggled(int);
    callback key-nav-down();
    callback key-nav-up();
    callback key-nav-activate();

    // ── Global keyboard shortcuts ──────────────────
    // Wizard-local keys (j/k/arrows/Enter) live inside WizardView's own
    // FocusScope; this scope only handles globally-meaningful shortcuts
    // and is unconditionally active outside of popups and the install
    // screen.
    main-focus-scope := FocusScope {
        enabled: InstallState.state == 0
            && !PopupState.select-visible
            && !PopupState.text-input-visible
            && !PopupState.users-visible
            && !PopupState.pkg-search-visible
            && !PopupState.strlist-visible
            && !PopupState.multi-select-visible
            && !PopupState.wifi-visible;
        key-pressed(e) => {
            if e.text == Key.Tab {
                WizardState.next();
                return accept;
            }
            if e.text == Key.Backtab {
                WizardState.back();
                return accept;
            }
            if e.text == "q" {
                quit-requested();
                return accept;
            }
            if e.text == "1" { WizardState.go-to(0); return accept; }
            if e.text == "2" { WizardState.go-to(1); return accept; }
            if e.text == "3" { WizardState.go-to(2); return accept; }
            if e.text == "4" { WizardState.go-to(3); return accept; }
            if e.text == "5" { WizardState.go-to(4); return accept; }
            if e.text == "6" { WizardState.go-to(5); return accept; }
            if e.text == "7" { WizardState.go-to(6); return accept; }
            return reject;
        }
    }

    // ── Welcome screen (step 0, no sidebar) ───────────
    if InstallState.state == 0 && WizardState.current-step == 0: WelcomeView { }

    // ── Wizard config screen (steps 1+, with sidebar) ──
    if InstallState.state == 0 && WizardState.current-step > 0: WizardView {
        item-activated(key) => { item-activated(key); }
        toggle-activated(key) => { toggle-activated(key); }
        install-requested() => { install-requested(); }
        quit-requested() => { quit-requested(); }
        key-nav-down() => { key-nav-down(); }
        key-nav-up() => { key-nav-up(); }
        key-nav-activate() => { key-nav-activate(); }
    }

    // ── Install progress screen ──────────────────────
    if InstallState.state >= 1: InstallView {
        quit-requested() => { quit-requested(); }
    }

    // ── Popup overlays ──────────────────────────────────

    SelectPopup {
        title: PopupState.select-title;
        options: PopupState.select-options;
        selected-index: PopupState.select-index;
        popup-visible: PopupState.select-visible;
        show-filter: PopupState.select-show-filter;

        accepted(idx) => {
            PopupState.select-visible = false;
            select-confirmed(PopupState.select-key, idx);
        }
        closed() => {
            PopupState.select-visible = false;
        }
        filter-changed(text) => {
            select-filter-changed(PopupState.select-key, text);
        }
    }

    TextInputPopup {
        title: PopupState.text-input-title;
        input-text: PopupState.text-input-value;
        is-password: PopupState.text-input-password;
        popup-visible: PopupState.text-input-visible;
        strength-score: PopupState.password-strength-score;
        strength-label: PopupState.password-strength-label;
        strength-hint: PopupState.password-strength-hint;
        strength-color: PopupState.password-strength-color;

        confirmed(val) => {
            PopupState.text-input-visible = false;
            text-confirmed(PopupState.text-input-key, val);
        }
        closed() => {
            PopupState.text-input-visible = false;
        }
        text-edited(val) => {
            text-input-edited(PopupState.text-input-key, val);
        }
    }

    UserManagePopup {
        users: EditingState.users;
        popup-visible: PopupState.users-visible;

        user-added(username, password, sudo) => {
            root.user-added(username, password, sudo);
        }
        user-removed(index) => { root.user-removed(index); }
        user-sudo-toggled(index) => { root.user-sudo-toggled(index); }
        // Reuse the same root callback as TextInputPopup for password
        // strength feedback. Rust filters by key.
        password-edited(val) => {
            text-input-edited("user_password", val);
        }
        closed() => { PopupState.users-visible = false; }
    }

    StringListPopup {
        title: PopupState.strlist-title;
        items: EditingState.extra-services;
        popup-visible: PopupState.strlist-visible;

        item-added(val) => { strlist-added(val); }
        item-removed(index) => { strlist-removed(index); }
        closed() => { PopupState.strlist-visible = false; }
    }

    MultiSelectPopup {
        title: PopupState.multi-select-title;
        options: EditingState.multi-select-options;
        popup-visible: PopupState.multi-select-visible;

        toggled(idx) => { multi-select-toggled(PopupState.multi-select-key, idx); }
        closed() => {
            PopupState.multi-select-visible = false;
            multi-select-closed(PopupState.multi-select-key);
        }
    }

    PackageSearchPopup {
        search-results: EditingState.package-search-results;
        selected-packages: EditingState.packages-selected;
        popup-visible: PopupState.pkg-search-visible;
        searching-aur: EditingState.package-searching-aur;
        status-text: EditingState.package-status-text;

        search-changed(text) => { root.pkg-search-changed(text); }
        search-aur(text) => { root.pkg-search-aur(text); }
        package-added(index) => { root.pkg-added(index); }
        package-removed(index) => { root.pkg-removed(index); }
        closed() => { PopupState.pkg-search-visible = false; }
    }

    WifiPopup {
        // Task #7 mounts the popup; task #8 fleshes out the inside.
        // All callbacks already go through WifiState as globals, so
        // the mount site has no per-callback plumbing.
        popup-visible: PopupState.wifi-visible;
    }
}
