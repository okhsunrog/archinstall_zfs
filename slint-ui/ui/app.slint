import { ListView, ScrollView } from "std-widgets.slint";

import { Catppuccin, Theme } from "styling.slint";
export { Catppuccin, Theme }

import { WizardState } from "state/wizard-state.slint";
export { WizardState }

import { EditingState } from "state/editing-state.slint";
export { EditingState }

import { ItemType, ConfigItem, SelectOption, UserEntry, PackageEntry, PackageSearchResult, LogMessage, DownloadInfo } from "types.slint";
export { ItemType, ConfigItem, SelectOption, UserEntry, PackageEntry, PackageSearchResult, LogMessage, DownloadInfo }

import { StyledButton } from "components/styled-button.slint";
import { StyledTextInput } from "components/styled-text-input.slint";
import { Badge } from "components/badge.slint";
import { ProgressBar } from "components/progress-bar.slint";
import { DeleteButton } from "components/delete-button.slint";
import { SidebarItem } from "components/sidebar-item.slint";
import { TextInputPopup } from "popups/text-input-popup.slint";
import { SelectPopup } from "popups/select-popup.slint";
import { UserManagePopup } from "popups/user-manage-popup.slint";
import { StringListPopup } from "popups/string-list-popup.slint";
import { PackageSearchPopup } from "popups/package-search-popup.slint";

// ── Main application ─────────────────────────────────

export component App inherits Window {
    background: Theme.c.base;
    preferred-width: 800px;
    preferred-height: 600px;
    title: "archinstall-zfs";
    forward-focus: main-focus-scope;

    // Welcome screen status
    in property <bool> net-ok: false;
    in property <bool> uefi-ok: false;
    in property <bool> zfs-ok: false;
    in property <bool> zfs-installing: false;
    in property <int> zfs-install-pct: 0;
    in property <string> zfs-install-status: "";

    out property <bool> all-checks-ok: net-ok && uefi-ok && zfs-ok;

    callback check-internet();

    in property <[ConfigItem]> config-items;

    // Select popup state
    in-out property <bool> select-visible: false;
    in-out property <string> select-title;
    in-out property <[SelectOption]> select-options;
    in-out property <int> select-index;
    in-out property <string> select-key;
    in-out property <bool> select-show-filter: false;

    // Text input popup state
    in-out property <bool> text-input-visible: false;
    in-out property <string> text-input-title;
    in-out property <string> text-input-value;
    in-out property <bool> text-input-password: false;
    in-out property <string> text-input-key;

    // Password strength (driven from Rust)
    in-out property <int> password-strength-score: -1;
    in-out property <string> password-strength-label;
    in-out property <string> password-strength-hint;
    in-out property <color> password-strength-color: Theme.c.overlay0;

    // User management popup state
    in-out property <bool> users-visible: false;

    // String list popup state
    in-out property <bool> strlist-visible: false;
    in-out property <string> strlist-title;
    in-out property <string> strlist-key;

    callback strlist-added(string, string); // key, value
    callback strlist-removed(string, int);  // key, index

    // Package search popup state
    in-out property <bool> pkg-search-visible: false;

    callback pkg-search-changed(string);
    callback pkg-search-aur(string);
    callback pkg-added(int);
    callback pkg-removed(int);

    // Install state: 0=config, 1=installing, 2=done, 3=failed
    in-out property <int> install-state: 0;

    // Log messages
    in property <[LogMessage]> log-messages;

    // Global install progress
    in property <string> install-phase-label: "Starting...";
    in property <int> install-phase: 0;
    in property <int> install-total-phases: 14;

    // Package download/install progress
    in property <[DownloadInfo]> download-items;
    in property <int> download-pct: 0;
    in property <string> download-status: "";
    in property <bool> download-active: false;

    // Status text
    in property <string> status-text;

    // Keyboard-driven focus index (-1 = none)
    in-out property <int> focused-index: -1;

    // Callbacks to Rust
    callback item-activated(string);
    callback select-confirmed(string, int);
    callback select-filter-changed(string, string); // (select-key, filter-text)
    callback text-confirmed(string, string);
    callback text-input-edited(string, string); // (text-input-key, current-text)
    callback toggle-activated(string);
    callback install-requested();
    callback quit-requested();
    callback user-added(string, string, bool); // username, password, sudo
    callback user-removed(int);
    callback user-sudo-toggled(int);
    callback key-nav-down();
    callback key-nav-up();
    callback key-nav-activate();

    // ── Keyboard navigation ─────────────────────────
    main-focus-scope := FocusScope {
        enabled: install-state == 0 && !select-visible && !text-input-visible && !users-visible && !pkg-search-visible && !strlist-visible;
        key-pressed(e) => {
            if e.text == Key.DownArrow || e.text == "j" {
                key-nav-down();
                return accept;
            }
            if e.text == Key.UpArrow || e.text == "k" {
                key-nav-up();
                return accept;
            }
            if e.text == Key.Return {
                key-nav-activate();
                return accept;
            }
            if e.text == Key.Tab {
                WizardState.next();
                return accept;
            }
            if e.text == Key.Backtab {
                WizardState.back();
                return accept;
            }
            if e.text == "q" {
                quit-requested();
                return accept;
            }
            if e.text == "1" { WizardState.go-to(0); return accept; }
            if e.text == "2" { WizardState.go-to(1); return accept; }
            if e.text == "3" { WizardState.go-to(2); return accept; }
            if e.text == "4" { WizardState.go-to(3); return accept; }
            if e.text == "5" { WizardState.go-to(4); return accept; }
            if e.text == "6" { WizardState.go-to(5); return accept; }
            if e.text == "7" { WizardState.go-to(6); return accept; }
            return reject;
        }
    }

    // ── Welcome screen (step 0, no sidebar) ───────────
    if install-state == 0 && WizardState.current-step == 0: Rectangle {
        background: Theme.c.base;

        VerticalLayout {
            alignment: center;
            spacing: 0px;

            // Centered content block
            HorizontalLayout {
                alignment: center;

                VerticalLayout {
                    width: min(500px, root.width - 60px);
                    spacing: 24px;
                    alignment: center;

                    // Title
                    VerticalLayout {
                        spacing: 8px;

                        Text {
                            text: "archinstall-zfs";
                            color: Theme.c.blue;
                            font-size: 36px;
                            font-weight: FontWeight.bold;
                            horizontal-alignment: center;
                        }

                        Text {
                            text: "Arch Linux installer with ZFS root";
                            color: Theme.c.subtext0;
                            font-size: 16px;
                            horizontal-alignment: center;
                        }
                    }

                    // Status cards
                    VerticalLayout {
                        spacing: 8px;

                        // Network status
                        Rectangle {
                            height: 48px;
                            background: Theme.c.surface0;
                            border-radius: 10px;

                            HorizontalLayout {
                                padding-left: 16px;
                                padding-right: 12px;
                                spacing: 12px;

                                Text {
                                    text: net-ok ? "\u{2713}" : "\u{2717}";
                                    color: net-ok ? Theme.c.green : Theme.c.red;
                                    font-size: 18px;
                                    vertical-alignment: center;
                                    width: 24px;
                                }

                                Text {
                                    text: "Internet connection";
                                    color: Theme.c.text;
                                    font-size: 14px;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                }

                                Text {
                                    text: net-ok ? "Connected" : "Not connected";
                                    color: net-ok ? Theme.c.green : Theme.c.overlay0;
                                    font-size: 13px;
                                    vertical-alignment: center;
                                }

                                if !net-ok: Rectangle {
                                    width: 90px;
                                    height: 30px;
                                    background: check-net-ta.has-hover ? Theme.c.surface1 : Theme.c.mantle;
                                    border-radius: 6px;

                                    check-net-ta := TouchArea {
                                        clicked => { check-internet(); }
                                    }

                                    Text {
                                        text: "Check again";
                                        color: Theme.c.blue;
                                        font-size: 12px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }

                        // UEFI status
                        Rectangle {
                            height: 48px;
                            background: Theme.c.surface0;
                            border-radius: 10px;

                            HorizontalLayout {
                                padding-left: 16px;
                                padding-right: 16px;
                                spacing: 12px;

                                Text {
                                    text: uefi-ok ? "\u{2713}" : "\u{2717}";
                                    color: uefi-ok ? Theme.c.green : Theme.c.red;
                                    font-size: 18px;
                                    vertical-alignment: center;
                                    width: 24px;
                                }

                                Text {
                                    text: "UEFI boot mode";
                                    color: Theme.c.text;
                                    font-size: 14px;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                }

                                Text {
                                    text: uefi-ok ? "Detected" : "Not detected (required)";
                                    color: uefi-ok ? Theme.c.green : Theme.c.red;
                                    font-size: 13px;
                                    vertical-alignment: center;
                                }
                            }
                        }

                        // ZFS status
                        Rectangle {
                            height: zfs-installing ? 72px : 48px;
                            background: Theme.c.surface0;
                            border-radius: 10px;

                            VerticalLayout {
                                padding: 0px;
                                spacing: 0px;

                                HorizontalLayout {
                                    height: 48px;
                                    padding-left: 16px;
                                    padding-right: 16px;
                                    spacing: 12px;

                                    Text {
                                        text: zfs-ok ? "\u{2713}"
                                            : zfs-installing ? "\u{21bb}"
                                            : "\u{2717}";
                                        color: zfs-ok ? Theme.c.green
                                            : zfs-installing ? Theme.c.blue
                                            : Theme.c.overlay0;
                                        font-size: 18px;
                                        vertical-alignment: center;
                                        width: 24px;
                                    }

                                    Text {
                                        text: "ZFS support";
                                        color: Theme.c.text;
                                        font-size: 14px;
                                        vertical-alignment: center;
                                        horizontal-stretch: 1;
                                    }

                                    Text {
                                        text: zfs-ok ? "Ready"
                                            : zfs-installing ? zfs-install-status
                                            : "Waiting for network...";
                                        color: zfs-ok ? Theme.c.green
                                            : zfs-installing ? Theme.c.blue
                                            : Theme.c.overlay0;
                                        font-size: 13px;
                                        vertical-alignment: center;
                                    }
                                }

                                // ZFS install progress bar
                                if zfs-installing: Rectangle {
                                    height: 6px;
                                    x: 16px;
                                    width: parent.width - 32px;
                                    background: Theme.c.mantle;
                                    border-radius: 3px;
                                    clip: true;

                                    Rectangle {
                                        x: 0; y: 0;
                                        height: parent.height;
                                        width: parent.width * zfs-install-pct / 100;
                                        background: Theme.c.blue;
                                        border-radius: 3px;
                                    }
                                }

                                // spacer at bottom when installing
                                if zfs-installing: Rectangle {
                                    height: 12px;
                                }
                            }
                        }
                    }

                    // Start button
                    HorizontalLayout {
                        alignment: center;

                        Rectangle {
                            width: 160px;
                            height: 44px;
                            background: all-checks-ok
                                ? (start-ta.has-hover ? Theme.c.sky : Theme.c.blue)
                                : Theme.c.surface1;
                            border-radius: 10px;

                            start-ta := TouchArea {
                                enabled: all-checks-ok;
                                mouse-cursor: self.enabled ? pointer : default;
                                clicked => { WizardState.go-to(1); }
                            }

                            Text {
                                text: "Get Started \u{2192}";
                                color: all-checks-ok ? Theme.c.base : Theme.c.overlay0;
                                font-size: 15px;
                                font-weight: FontWeight.semi-bold;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }

                    // Version
                    Text {
                        text: "v0.1.0";
                        color: Theme.c.overlay0;
                        font-size: 11px;
                        horizontal-alignment: center;
                    }
                }
            }
        }
    }

    // ── Wizard config screen (steps 1+, with sidebar) ──
    if install-state == 0 && WizardState.current-step > 0: VerticalLayout {
        padding: 0px;
        spacing: 0px;

        // Title bar
        Rectangle {
            height: 48px;
            background: Theme.c.mantle;

            HorizontalLayout {
                padding-left: 16px;
                padding-right: 16px;

                Text {
                    text: "archinstall-zfs";
                    color: Theme.c.blue;
                    font-size: 22px;
                    font-weight: FontWeight.bold;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }

                Text {
                    text: WizardState.current-step + " / " + (WizardState.total-steps - 1);
                    color: Theme.c.overlay0;
                    font-size: 14px;
                    vertical-alignment: center;
                }
            }
        }

        // Body: sidebar + content
        HorizontalLayout {
            spacing: 0px;

            // Sidebar (skip Welcome in sidebar, show steps 1-6)
            Rectangle {
                width: 140px;
                background: Theme.c.mantle;

                VerticalLayout {
                    padding: 8px;
                    spacing: 2px;
                    alignment: start;

                    for label[index] in WizardState.step-labels: SidebarItem {
                        visible: index > 0;
                        label: label;
                        state: WizardState.step-state-at(index);
                        step-index: index;

                        clicked => {
                            if index <= WizardState.max-visited {
                                WizardState.go-to(index);
                            }
                        }
                    }
                }
            }

            // Vertical separator
            Rectangle {
                width: 1px;
                background: Theme.c.surface1;
            }

            // Content area
            VerticalLayout {
                spacing: 0px;

                // Step title
                Rectangle {
                    height: 40px;
                    background: transparent;

                    HorizontalLayout {
                        padding-left: 16px;
                        alignment: start;

                        Text {
                            text: WizardState.current-step < WizardState.step-labels.length
                                ? WizardState.step-labels[WizardState.current-step] : "";
                            color: Theme.c.mauve;
                            font-size: 18px;
                            font-weight: FontWeight.semi-bold;
                            vertical-alignment: center;
                        }
                    }
                }

                // Config items list — card-based design
                ScrollView {
                    VerticalLayout {
                        spacing: 2px;
                        padding: 8px;
                        padding-left: 12px;
                        padding-right: 12px;

                        for item[index] in config-items: Rectangle {
                            // Heights
                            height: item.item-type == ItemType.separator ? 12px      // separator gap
                                  : item.item-type == ItemType.warning ? 32px      // warning
                                  : item.item-type == ItemType.radio-header ? 36px      // radio card header
                                  : item.item-type == ItemType.radio-option ? 36px      // radio option
                                  : item.item-type == ItemType.action ? 40px      // action button
                                  : 44px;                           // normal items

                            // Card backgrounds
                            border-radius: item.item-type == ItemType.radio-header ? 8px    // radio header: top corners only visually
                                         : item.item-type == ItemType.separator ? 0px
                                         : item.item-type == ItemType.warning ? 6px
                                         : 8px;

                            background: item.item-type == ItemType.separator ? transparent
                                      : item.item-type == ItemType.radio-header ? Theme.c.surface0  // radio header = card top
                                      : item.item-type == ItemType.radio-option ? Theme.c.surface0  // radio body = card body
                                      : item.item-type == ItemType.warning ? transparent
                                      : item.item-type == ItemType.action ? transparent       // actions = no card bg
                                      : item.item-type == ItemType.readonly ? Theme.c.surface0  // readonly = card
                                      : Theme.c.surface0;                       // normal items = card

                            // Hover highlight
                            Rectangle {
                                visible: (row-ta.has-hover || index == focused-index)
                                    && item.item-type != ItemType.separator
                                    && item.item-type != ItemType.readonly
                                    && item.item-type != ItemType.warning
                                    && item.item-type != ItemType.radio-header;
                                background: #ffffff10;
                                border-radius: parent.border-radius;
                            }

                            // ── Separator ──
                            if item.item-type == ItemType.separator: Rectangle { }

                            // ── Warning ──
                            if item.item-type == ItemType.warning: HorizontalLayout {
                                padding-left: 12px;
                                spacing: 8px;
                                alignment: start;

                                Text {
                                    text: "\u{26a0}";
                                    color: Theme.c.yellow;
                                    font-size: 14px;
                                    vertical-alignment: center;
                                }
                                Text {
                                    text: item.value;
                                    color: Theme.c.yellow;
                                    font-size: 13px;
                                    vertical-alignment: center;
                                }
                            }

                            // ── Radio group header (card title bar) ──
                            if item.item-type == ItemType.radio-header: HorizontalLayout {
                                padding-left: 14px;
                                alignment: start;

                                Text {
                                    text: item.label;
                                    color: Theme.c.blue;
                                    font-size: 13px;
                                    font-weight: FontWeight.semi-bold;
                                    vertical-alignment: center;
                                }
                            }

                            // ── Radio option (card body row) ──
                            if item.item-type == ItemType.radio-option: HorizontalLayout {
                                padding-left: 14px;
                                padding-right: 14px;
                                spacing: 10px;
                                alignment: start;

                                Text {
                                    text: item.value == "selected" ? "\u{25cf}" : "\u{25cb}";
                                    color: item.value == "selected" ? Theme.c.green : Theme.c.overlay0;
                                    font-size: 16px;
                                    vertical-alignment: center;
                                    width: 18px;
                                }

                                Text {
                                    text: item.label;
                                    color: item.value == "selected" ? Theme.c.text : Theme.c.subtext0;
                                    font-size: 14px;
                                    vertical-alignment: center;
                                }
                            }

                            // ── Action button ──
                            if item.item-type == ItemType.action: Rectangle {
                                background: item.key == "install" ? Theme.c.blue : Theme.c.surface0;
                                border-radius: 8px;

                                Rectangle {
                                    visible: row-ta.has-hover || index == focused-index;
                                    background: #ffffff18;
                                    border-radius: parent.border-radius;
                                }

                                Text {
                                    text: item.label;
                                    color: item.key == "install" ? Theme.c.base : Theme.c.text;
                                    font-size: 14px;
                                    font-weight: FontWeight.semi-bold;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }

                            // ── Read-only summary (review step) ──
                            if item.item-type == ItemType.readonly: HorizontalLayout {
                                padding-left: 14px;
                                padding-right: 14px;

                                Text {
                                    text: item.label;
                                    color: Theme.c.subtext0;
                                    font-size: 13px;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                }

                                Text {
                                    text: item.value;
                                    color: item.value == "Not set" || item.value == "None" || item.value == "Disabled"
                                        ? Theme.c.overlay0
                                        : Theme.c.green;
                                    font-size: 13px;
                                    vertical-alignment: center;
                                }
                            }

                            // ── Normal config items (text, select, password, toggle) ──
                            if item.item-type == ItemType.text || item.item-type == ItemType.select
                                || item.item-type == ItemType.password || item.item-type == ItemType.toggle: HorizontalLayout {
                                padding-left: 14px;
                                padding-right: 14px;

                                Text {
                                    text: item.label;
                                    color: Theme.c.subtext1;
                                    font-size: 14px;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                }

                                // Type indicator + value
                                HorizontalLayout {
                                    spacing: 6px;
                                    alignment: end;

                                    // Toggle indicator
                                    if item.item-type == ItemType.toggle: Text {
                                        text: item.value == "Enabled" ? "\u{25cf}" : "\u{25cb}";
                                        color: item.value == "Enabled" ? Theme.c.green : Theme.c.overlay0;
                                        font-size: 14px;
                                        vertical-alignment: center;
                                    }

                                    Text {
                                        text: item.value;
                                        color: item.value == "Not set" || item.value == "None" || item.value == "Disabled"
                                            ? Theme.c.overlay0
                                            : Theme.c.green;
                                        font-size: 14px;
                                        vertical-alignment: center;
                                    }
                                }
                            }

                            // ── Touch area (for all item types) ──
                            row-ta := TouchArea {
                                mouse-cursor: item.item-type == ItemType.separator || item.item-type == ItemType.readonly
                                    || item.item-type == ItemType.warning || item.item-type == ItemType.radio-header
                                    ? default : pointer;
                                clicked => {
                                    focused-index = index;
                                    if item.item-type == ItemType.action {
                                        if item.key == "install" { install-requested(); }
                                        if item.key == "quit" { quit-requested(); }
                                    } else if item.item-type == ItemType.toggle {
                                        toggle-activated(item.key);
                                    } else if item.item-type != ItemType.separator
                                           && item.item-type != ItemType.readonly
                                           && item.item-type != ItemType.warning
                                           && item.item-type != ItemType.radio-header {
                                        item-activated(item.key);
                                    }
                                }
                            }
                        }
                    }
                }

                // Footer with navigation buttons
                Rectangle {
                    height: 44px;
                    background: Theme.c.mantle;

                    HorizontalLayout {
                        padding-left: 16px;
                        padding-right: 16px;
                        spacing: 8px;
                        alignment: center;

                        // Quit button
                        Rectangle {
                            width: 60px;
                            height: 32px;
                            background: quit-nav-ta.has-hover ? Theme.c.surface1 : transparent;
                            border-radius: 4px;

                            quit-nav-ta := TouchArea {
                                clicked => { quit-requested(); }
                            }

                            Text {
                                text: "Quit";
                                color: Theme.c.overlay0;
                                font-size: 13px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }

                        // Back button (not on first wizard step)
                        if WizardState.current-step > 1: Rectangle {
                            width: 80px;
                            height: 32px;
                            background: back-ta.has-hover ? Theme.c.surface1 : Theme.c.surface0;
                            border-radius: 4px;

                            back-ta := TouchArea {
                                clicked => { WizardState.back(); }
                            }

                            Text {
                                text: "\u{25c2} Back";
                                color: Theme.c.subtext0;
                                font-size: 13px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }

                        // Status text
                        Text {
                            text: status-text;
                            color: Theme.c.overlay0;
                            font-size: 12px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }

                        // Next button
                        if WizardState.current-step < WizardState.total-steps - 1: Rectangle {
                            width: 80px;
                            height: 32px;
                            background: next-ta.has-hover ? Theme.c.sky : Theme.c.blue;
                            border-radius: 4px;

                            next-ta := TouchArea {
                                clicked => { WizardState.next(); }
                            }

                            Text {
                                text: "Next \u{25b8}";
                                color: Theme.c.base;
                                font-size: 13px;
                                font-weight: FontWeight.semi-bold;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }
        }
    }

    // ── Install progress screen ──────────────────────
    if install-state >= 1: VerticalLayout {
        padding: 12px;
        spacing: 8px;

        // ── Log area (fills available space) ────────
        log-view := ListView {
            for msg[index] in log-messages: Rectangle {
                height: msg-text.preferred-height + 4px;

                msg-text := Text {
                    text: msg.text;
                    color: msg.level == 4 ? Theme.c.red
                         : msg.level == 3 ? Theme.c.yellow
                         : msg.level == 2 ? Theme.c.green
                         : msg.level == 1 ? Theme.c.blue
                         : Theme.c.overlay0;
                    font-family: "monospace";
                    font-size: 12px;
                    x: 8px;
                    width: parent.width - 16px;
                    wrap: word-wrap;
                    vertical-alignment: center;
                }
            }
        }

        property <int> scroll-trigger: log-messages.length;
        changed scroll-trigger => {
            log-view.viewport-y = -100000px;
        }

        // ── Progress card (always visible during install) ──
        Rectangle {
            height: download-active ? 180px : 80px;
            background: Theme.c.surface0;
            border-radius: 10px;

            VerticalLayout {
                padding: 14px;
                spacing: 8px;

                // Global phase status
                HorizontalLayout {
                    spacing: 10px;

                    Text {
                        text: install-state == 2 ? "\u{2713} Complete"
                            : install-state == 3 ? "\u{2717} Failed"
                            : install-phase-label;
                        color: install-state == 2 ? Theme.c.green
                            : install-state == 3 ? Theme.c.red
                            : Theme.c.text;
                        font-size: 14px;
                        font-weight: FontWeight.semi-bold;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                    }

                    Text {
                        text: install-state >= 2 ? ""
                            : install-phase + " / " + install-total-phases;
                        color: Theme.c.overlay0;
                        font-size: 13px;
                        vertical-alignment: center;
                    }
                }

                // Global progress bar
                if install-state == 1: Rectangle {
                    height: 8px;
                    background: Theme.c.mantle;
                    border-radius: 4px;
                    clip: true;

                    Rectangle {
                        x: 0; y: 0;
                        height: parent.height;
                        width: parent.width * install-phase / install-total-phases;
                        background: Theme.c.blue;
                        border-radius: 4px;
                    }
                }

                // Package progress (download or install)
                if download-active: VerticalLayout {
                    spacing: 6px;

                    // Download/install status line
                    HorizontalLayout {
                        Text {
                            text: download-status;
                            color: Theme.c.teal;
                            font-size: 12px;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }

                        Text {
                            text: download-pct + "%";
                            color: Theme.c.teal;
                            font-size: 12px;
                            font-weight: FontWeight.semi-bold;
                            vertical-alignment: center;
                        }
                    }

                    // Package progress bar
                    Rectangle {
                        height: 6px;
                        background: Theme.c.mantle;
                        border-radius: 3px;
                        clip: true;

                        Rectangle {
                            x: 0; y: 0;
                            height: parent.height;
                            width: parent.width * download-pct / 100;
                            background: Theme.c.teal;
                            border-radius: 3px;
                        }
                    }

                    // Per-package lines
                    ListView {
                        for dl[index] in download-items: Rectangle {
                            height: 18px;

                            HorizontalLayout {
                                padding-left: 4px;
                                padding-right: 4px;
                                spacing: 8px;

                                Text {
                                    text: dl.filename;
                                    color: dl.state == 1 ? Theme.c.overlay0
                                         : dl.state == 2 ? Theme.c.green
                                         : Theme.c.text;
                                    font-size: 11px;
                                    font-family: "monospace";
                                    overflow: elide;
                                    horizontal-stretch: 1;
                                    vertical-alignment: center;
                                }

                                Text {
                                    text: dl.state == 1 ? "verifying..."
                                         : dl.state == 2 ? "done"
                                         : dl.pct + "% " + dl.speed;
                                    color: dl.state == 2 ? Theme.c.green : Theme.c.overlay0;
                                    font-size: 11px;
                                    font-family: "monospace";
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }
                }

                // Exit button
                if install-state >= 2: Rectangle {
                    height: 36px;
                    background: exit-ta.has-hover ? Theme.c.blue : Theme.c.surface1;
                    border-radius: 8px;

                    exit-ta := TouchArea {
                        clicked => { quit-requested(); }
                    }

                    Text {
                        text: install-state == 2 ? "Reboot" : "Exit";
                        color: exit-ta.has-hover ? Theme.c.base : Theme.c.text;
                        font-size: 14px;
                        font-weight: FontWeight.semi-bold;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }

    // ── Popup overlays ──────────────────────────────────

    SelectPopup {
        title: select-title;
        options: select-options;
        selected-index: select-index;
        popup-visible: select-visible;
        show-filter: select-show-filter;

        accepted(idx) => {
            select-visible = false;
            select-confirmed(select-key, idx);
        }
        cancelled() => {
            select-visible = false;
        }
        filter-changed(text) => {
            select-filter-changed(select-key, text);
        }
    }

    TextInputPopup {
        title: text-input-title;
        input-text: text-input-value;
        is-password: text-input-password;
        popup-visible: text-input-visible;
        strength-score: password-strength-score;
        strength-label: password-strength-label;
        strength-hint: password-strength-hint;
        strength-color: password-strength-color;

        confirmed(val) => {
            text-input-visible = false;
            text-confirmed(text-input-key, val);
        }
        cancelled() => {
            text-input-visible = false;
        }
        text-edited(val) => {
            text-input-edited(text-input-key, val);
        }
    }

    UserManagePopup {
        users: EditingState.users;
        popup-visible: users-visible;

        user-added(username, password, sudo) => {
            root.user-added(username, password, sudo);
        }
        user-removed(index) => {
            root.user-removed(index);
        }
        user-sudo-toggled(index) => {
            root.user-sudo-toggled(index);
        }
        closed() => {
            users-visible = false;
        }
    }

    StringListPopup {
        title: strlist-title;
        items: EditingState.extra-services;
        popup-visible: strlist-visible;

        item-added(val) => {
            strlist-added(strlist-key, val);
        }
        item-removed(index) => {
            strlist-removed(strlist-key, index);
        }
        closed() => {
            strlist-visible = false;
        }
    }

    PackageSearchPopup {
        search-results: EditingState.package-search-results;
        selected-packages: EditingState.packages-selected;
        popup-visible: pkg-search-visible;
        searching-aur: EditingState.package-searching-aur;
        status-text: EditingState.package-status-text;

        search-changed(text) => {
            root.pkg-search-changed(text);
        }
        search-aur(text) => {
            root.pkg-search-aur(text);
        }
        package-added(index) => {
            root.pkg-added(index);
        }
        package-removed(index) => {
            root.pkg-removed(index);
        }
        closed() => {
            pkg-search-visible = false;
        }
    }
}
