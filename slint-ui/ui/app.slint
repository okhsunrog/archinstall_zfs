import { ListView, ScrollView } from "std-widgets.slint";

// Catppuccin Mocha color palette
export struct Catppuccin {
    base: color,
    mantle: color,
    surface0: color,
    surface1: color,
    overlay0: color,
    text: color,
    subtext0: color,
    subtext1: color,
    blue: color,
    green: color,
    red: color,
    yellow: color,
    mauve: color,
    teal: color,
    sky: color,
    peach: color,
}

export global Theme {
    out property <Catppuccin> c: {
        base: #1e1e2e,
        mantle: #181825,
        surface0: #313244,
        surface1: #45475a,
        overlay0: #6c7086,
        text: #cdd6f4,
        subtext0: #a6adc8,
        subtext1: #bac2de,
        blue: #89b4fa,
        green: #a6e3a1,
        red: #f38ba8,
        yellow: #f9e2af,
        mauve: #cba6f7,
        teal: #94e2d5,
        sky: #89dceb,
        peach: #fab387,
    };
}

export struct ConfigItem {
    key: string,
    label: string,
    value: string,
    item-type: int, // 0=text, 1=select, 2=password, 3=toggle, 4=separator, 5=action,
                    // 6=readonly, 7=warning, 8=radio-header, 9=radio-option
}

export struct SelectOption {
    text: string,
}

export struct UserEntry {
    username: string,
    has-sudo: bool,
}

export struct PackageEntry {
    name: string,
    repo: string,  // "extra", "core", "aur", etc.
}

export struct PackageSearchResult {
    name: string,
    description: string,
    repo: string,
}

export struct LogMessage {
    text: string,
    level: int,
}

export struct DownloadInfo {
    filename: string,
    pct: int,
    speed: string,
    state: int, // 0=downloading, 1=verifying, 2=done
}

export struct StepInfo {
    label: string,
    state: int, // 0=pending, 1=current, 2=done
}

// ── Text input popup ─────────────────────────────────

component TextInputPopup inherits Rectangle {
    in property <string> title;
    in-out property <string> input-text;
    in property <bool> is-password: false;
    in property <bool> popup-visible;
    // Password strength (set from Rust)
    in property <int> strength-score: -1; // -1=hidden, 0..4=zxcvbn score
    in property <string> strength-label;
    in property <string> strength-hint; // crack time or suggestion
    in property <color> strength-color: Theme.c.overlay0;

    callback confirmed(string);
    callback cancelled();
    callback text-edited(string);

    if popup-visible: Rectangle {
        background: #00000080;
        width: 100%; height: 100%;

        TouchArea { clicked => { cancelled(); } }

        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: min(500px, parent.width - 40px);
            height: self.preferred-height;
            background: Theme.c.mantle;
            border-radius: 8px;
            border-color: Theme.c.surface1;
            border-width: 1px;
            accessible-role: groupbox;
            accessible-label: title;

            VerticalLayout {
                padding: 16px;
                spacing: 12px;

                Text {
                    text: title;
                    color: Theme.c.blue;
                    font-size: 16px;
                    font-weight: FontWeight.semi-bold;
                }

                Rectangle {
                    height: 36px;
                    background: Theme.c.surface0;
                    border-radius: 4px;
                    border-color: Theme.c.blue;
                    border-width: 1px;
                    clip: true;

                    input := TextInput {
                        width: max(parent.width - 16px, self.preferred-width);
                        x: 8px;
                        vertical-alignment: center;
                        color: Theme.c.text;
                        font-size: 14px;
                        text: input-text;
                        input-type: is-password ? InputType.password : InputType.text;

                        private property <length> margin: 8px;
                        cursor-position-changed(cursor-position) => {
                            if cursor-position.x + self.x < margin {
                                self.x = - cursor-position.x + margin;
                            } else if cursor-position.x + self.x > parent.width - margin - self.text-cursor-width {
                                self.x = parent.width - cursor-position.x - margin - self.text-cursor-width;
                            }
                        }

                        edited => {
                            text-edited(self.text);
                        }

                        accepted => {
                            confirmed(self.text);
                        }
                    }

                    init => { input.focus(); }
                }

                // Password strength bar
                if is-password && strength-score >= 0: VerticalLayout {
                    spacing: 4px;

                    Rectangle {
                        height: 6px;
                        background: Theme.c.surface0;
                        border-radius: 3px;
                        clip: true;

                        Rectangle {
                            x: 0;
                            y: 0;
                            height: parent.height;
                            width: parent.width * (strength-score + 1) / 5;
                            background: strength-color;
                            border-radius: 3px;
                        }
                    }

                    HorizontalLayout {
                        alignment: center;
                        spacing: 12px;

                        Text {
                            text: strength-label;
                            color: strength-color;
                            font-size: 12px;
                            font-weight: FontWeight.semi-bold;
                        }

                        if strength-hint != "": Text {
                            text: strength-hint;
                            color: Theme.c.overlay0;
                            font-size: 12px;
                        }
                    }
                }

                HorizontalLayout {
                    spacing: 8px;
                    alignment: end;

                    Rectangle {
                        width: 80px;
                        height: 30px;
                        background: cancel-ta.has-hover ? Theme.c.surface1 : Theme.c.surface0;
                        border-radius: 4px;
                        accessible-role: button;
                        accessible-label: "Cancel";

                        cancel-ta := TouchArea {
                            clicked => { cancelled(); }
                        }

                        Text {
                            text: "Cancel";
                            color: Theme.c.subtext0;
                            font-size: 13px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    Rectangle {
                        width: 80px;
                        height: 30px;
                        background: ok-ta.has-hover ? Theme.c.sky : Theme.c.blue;
                        border-radius: 4px;
                        accessible-role: button;
                        accessible-label: "OK";

                        ok-ta := TouchArea {
                            clicked => { confirmed(input.text); }
                        }

                        Text {
                            text: "OK";
                            color: Theme.c.base;
                            font-size: 13px;
                            font-weight: FontWeight.semi-bold;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }
}

// ── Select popup ─────────────────────────────────────

component SelectPopup inherits Rectangle {
    in property <string> title;
    in property <[SelectOption]> options;
    in property <int> selected-index;
    out property <int> result-index: selected-index;
    in property <bool> popup-visible;
    in property <bool> show-filter: false;

    callback accepted(int);
    callback cancelled();
    callback filter-changed(string);

    if popup-visible: Rectangle {
        background: #00000080;
        width: 100%; height: 100%;

        TouchArea {
            clicked => { cancelled(); }
            scroll-event(e) => {
                return accept;
            }
        }

        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: min(500px, parent.width - 40px);
            height: min(parent.height - 80px, 500px);
            background: Theme.c.mantle;
            border-radius: 8px;
            border-color: Theme.c.surface1;
            border-width: 1px;
            clip: true;
            accessible-role: groupbox;
            accessible-label: title;

            VerticalLayout {
                padding: 16px;
                spacing: 8px;

                Text {
                    text: title;
                    color: Theme.c.blue;
                    font-size: 16px;
                    font-weight: FontWeight.semi-bold;
                    height: 24px;
                }

                if show-filter: Rectangle {
                    height: 32px;
                    background: Theme.c.surface0;
                    border-radius: 4px;
                    border-color: Theme.c.blue;
                    border-width: 1px;
                    clip: true;

                    filter-input := TextInput {
                        width: max(parent.width - 16px, self.preferred-width);
                        x: 8px;
                        vertical-alignment: center;
                        color: Theme.c.text;
                        font-size: 13px;

                        private property <length> margin: 8px;
                        cursor-position-changed(cursor-position) => {
                            if cursor-position.x + self.x < margin {
                                self.x = - cursor-position.x + margin;
                            } else if cursor-position.x + self.x > parent.width - margin - self.text-cursor-width {
                                self.x = parent.width - cursor-position.x - margin - self.text-cursor-width;
                            }
                        }

                        edited => {
                            filter-changed(self.text);
                        }
                    }

                    init => { filter-input.focus(); }
                }

                ListView {
                    for option[index] in options: Rectangle {
                        height: 32px;
                        background: item-ta.has-hover ? Theme.c.surface1
                                  : index == result-index ? Theme.c.surface0
                                  : transparent;
                        border-radius: 4px;
                        accessible-role: list-item;
                        accessible-label: option.text;
                        accessible-item-selected: index == result-index;
                        accessible-item-index: index;
                        accessible-item-count: options.length;

                        item-ta := TouchArea {
                            clicked => {
                                result-index = index;
                                accepted(index);
                            }
                        }

                        HorizontalLayout {
                            padding-left: 12px;
                            alignment: start;

                            Text {
                                text: index == result-index ? "> " + option.text : "  " + option.text;
                                color: index == result-index ? Theme.c.green : Theme.c.text;
                                font-size: 14px;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }
        }
    }
}

// ── User management popup ────────────────────────────

component UserManagePopup inherits Rectangle {
    in property <[UserEntry]> users;
    in property <bool> popup-visible;

    callback user-added(string, string, bool); // username, password, sudo
    callback user-removed(int);
    callback user-sudo-toggled(int);
    callback closed();

    if popup-visible: Rectangle {
        background: #00000080;
        width: 100%; height: 100%;

        TouchArea { clicked => { closed(); } }

        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: min(520px, parent.width - 40px);
            height: min(parent.height - 80px, 480px);
            background: Theme.c.mantle;
            border-radius: 8px;
            border-color: Theme.c.surface1;
            border-width: 1px;
            clip: true;
            accessible-role: groupbox;
            accessible-label: "User accounts";

            VerticalLayout {
                padding: 16px;
                spacing: 12px;

                Text {
                    text: "User accounts";
                    color: Theme.c.blue;
                    font-size: 16px;
                    font-weight: FontWeight.semi-bold;
                    height: 24px;
                }

                // ── Existing users list ──
                ListView {
                    vertical-stretch: 1;

                    for user[index] in users: Rectangle {
                        height: 40px;
                        background: user-row-ta.has-hover ? Theme.c.surface1 : Theme.c.surface0;
                        border-radius: 4px;

                        user-row-ta := TouchArea {
                            clicked => { user-sudo-toggled(index); }
                        }

                        HorizontalLayout {
                            padding-left: 12px;
                            padding-right: 8px;
                            spacing: 8px;
                            alignment: space-between;

                            HorizontalLayout {
                                spacing: 8px;
                                alignment: start;

                                Text {
                                    text: user.username;
                                    color: Theme.c.text;
                                    font-size: 14px;
                                    vertical-alignment: center;
                                }

                                if user.has-sudo: Rectangle {
                                    width: sudo-text.preferred-width + 12px;
                                    height: 20px;
                                    background: Theme.c.blue;
                                    border-radius: 3px;

                                    sudo-text := Text {
                                        text: "sudo";
                                        color: Theme.c.base;
                                        font-size: 11px;
                                        font-weight: FontWeight.semi-bold;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }

                                if !user.has-sudo: Text {
                                    text: "(click to toggle sudo)";
                                    color: Theme.c.overlay0;
                                    font-size: 12px;
                                }
                            }

                            Rectangle {
                                width: 28px;
                                height: 28px;
                                background: del-ta.has-hover ? Theme.c.red : transparent;
                                border-radius: 4px;

                                del-ta := TouchArea {
                                    clicked => { user-removed(index); }
                                }

                                Text {
                                    text: "\u{2715}"; // ✕
                                    color: del-ta.has-hover ? Theme.c.base : Theme.c.overlay0;
                                    font-size: 14px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }
                }

                // ── Add user form ──
                Rectangle {
                    height: 1px;
                    background: Theme.c.surface1;
                }

                Text {
                    text: "Add user";
                    color: Theme.c.subtext0;
                    font-size: 13px;
                    font-weight: FontWeight.semi-bold;
                    height: 20px;
                }

                HorizontalLayout {
                    spacing: 8px;

                    // Username
                    Rectangle {
                        horizontal-stretch: 1;
                        height: 34px;
                        background: Theme.c.surface0;
                        border-radius: 4px;
                        border-color: username-input.has-focus ? Theme.c.blue : Theme.c.surface1;
                        border-width: 1px;
                        clip: true;

                        username-input := TextInput {
                            width: max(parent.width - 16px, self.preferred-width);
                            x: 8px;
                            vertical-alignment: center;
                            color: Theme.c.text;
                            font-size: 13px;

                            private property <length> margin: 8px;
                            cursor-position-changed(cursor-position) => {
                                if cursor-position.x + self.x < margin {
                                    self.x = - cursor-position.x + margin;
                                } else if cursor-position.x + self.x > parent.width - margin - self.text-cursor-width {
                                    self.x = parent.width - cursor-position.x - margin - self.text-cursor-width;
                                }
                            }
                        }

                        // Placeholder
                        if username-input.text == "": Text {
                            x: 8px;
                            text: "username";
                            color: Theme.c.overlay0;
                            font-size: 13px;
                            vertical-alignment: center;
                        }
                    }

                    // Password
                    Rectangle {
                        horizontal-stretch: 1;
                        height: 34px;
                        background: Theme.c.surface0;
                        border-radius: 4px;
                        border-color: password-input.has-focus ? Theme.c.blue : Theme.c.surface1;
                        border-width: 1px;
                        clip: true;

                        password-input := TextInput {
                            width: max(parent.width - 16px, self.preferred-width);
                            x: 8px;
                            vertical-alignment: center;
                            color: Theme.c.text;
                            font-size: 13px;
                            input-type: InputType.password;

                            private property <length> margin: 8px;
                            cursor-position-changed(cursor-position) => {
                                if cursor-position.x + self.x < margin {
                                    self.x = - cursor-position.x + margin;
                                } else if cursor-position.x + self.x > parent.width - margin - self.text-cursor-width {
                                    self.x = parent.width - cursor-position.x - margin - self.text-cursor-width;
                                }
                            }
                        }

                        // Placeholder
                        if password-input.text == "": Text {
                            x: 8px;
                            text: "password (optional)";
                            color: Theme.c.overlay0;
                            font-size: 13px;
                            vertical-alignment: center;
                        }
                    }
                }

                HorizontalLayout {
                    spacing: 8px;
                    alignment: end;

                    // Sudo toggle
                    sudo-toggle := Rectangle {
                        height: 30px;
                        width: sudo-check-text.preferred-width + 36px;
                        background: sudo-ta.has-hover ? Theme.c.surface1 : Theme.c.surface0;
                        border-radius: 4px;

                        property <bool> sudo-checked: true;

                        sudo-ta := TouchArea {
                            clicked => { parent.sudo-checked = !parent.sudo-checked; }
                        }

                        HorizontalLayout {
                            padding-left: 10px;
                            padding-right: 10px;
                            spacing: 6px;
                            alignment: center;

                            Text {
                                text: sudo-toggle.sudo-checked ? "\u{25cf}" : "\u{25cb}";
                                color: sudo-toggle.sudo-checked ? Theme.c.green : Theme.c.overlay0;
                                font-size: 14px;
                                vertical-alignment: center;
                            }

                            sudo-check-text := Text {
                                text: "sudo";
                                color: Theme.c.subtext0;
                                font-size: 13px;
                                vertical-alignment: center;
                            }
                        }
                    }

                    // Add button
                    Rectangle {
                        width: 80px;
                        height: 30px;
                        background: add-ta.has-hover ? Theme.c.sky : Theme.c.blue;
                        border-radius: 4px;
                        accessible-role: button;
                        accessible-label: "Add";

                        add-ta := TouchArea {
                            clicked => {
                                if username-input.text != "" {
                                    user-added(username-input.text, password-input.text, sudo-toggle.sudo-checked);
                                    sudo-toggle.sudo-checked = true;
                                    username-input.text = "";
                                    password-input.text = "";
                                    username-input.focus();
                                }
                            }
                        }

                        Text {
                            text: "Add";
                            color: Theme.c.base;
                            font-size: 13px;
                            font-weight: FontWeight.semi-bold;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }

                // ── Done button ──
                HorizontalLayout {
                    alignment: end;

                    Rectangle {
                        width: 80px;
                        height: 30px;
                        background: done-ta.has-hover ? Theme.c.surface1 : Theme.c.surface0;
                        border-radius: 4px;
                        accessible-role: button;
                        accessible-label: "Done";

                        done-ta := TouchArea {
                            clicked => { closed(); }
                        }

                        Text {
                            text: "Done";
                            color: Theme.c.subtext0;
                            font-size: 13px;
                            font-weight: FontWeight.semi-bold;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }
}

// ── String list popup (for extra_services, etc.) ────

component StringListPopup inherits Rectangle {
    in property <string> title;
    in property <[SelectOption]> items;
    in property <bool> popup-visible;

    callback item-added(string);
    callback item-removed(int);
    callback closed();

    if popup-visible: Rectangle {
        background: #00000080;
        width: 100%; height: 100%;

        TouchArea { clicked => { closed(); } }

        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: min(460px, parent.width - 40px);
            height: self.preferred-height;
            background: Theme.c.mantle;
            border-radius: 8px;
            border-color: Theme.c.surface1;
            border-width: 1px;
            clip: true;
            accessible-role: groupbox;
            accessible-label: title;

            VerticalLayout {
                padding: 16px;
                spacing: 10px;

                Text {
                    text: title;
                    color: Theme.c.blue;
                    font-size: 16px;
                    font-weight: FontWeight.semi-bold;
                    height: 24px;
                }

                // Existing items
                ListView {
                    vertical-stretch: 1;

                    for item[index] in items: Rectangle {
                        height: 40px;
                        background: transparent;

                        Rectangle {
                            y: 2px;
                            height: 36px;
                            background: Theme.c.surface0;
                            border-radius: 4px;
                        }

                        HorizontalLayout {
                            padding-left: 12px;
                            padding-right: 8px;
                            alignment: space-between;

                            Text {
                                text: item.text;
                                color: Theme.c.text;
                                font-size: 14px;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                            }

                            Rectangle {
                                width: 28px;
                                height: 28px;
                                background: sl-del-ta.has-hover ? Theme.c.red : transparent;
                                border-radius: 4px;

                                sl-del-ta := TouchArea {
                                    clicked => { item-removed(index); }
                                }

                                Text {
                                    text: "\u{2715}";
                                    color: sl-del-ta.has-hover ? Theme.c.base : Theme.c.overlay0;
                                    font-size: 14px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }
                }

                // Add new item
                HorizontalLayout {
                    spacing: 8px;

                    Rectangle {
                        horizontal-stretch: 1;
                        height: 34px;
                        background: Theme.c.surface0;
                        border-radius: 4px;
                        border-color: sl-add-input.has-focus ? Theme.c.blue : Theme.c.surface1;
                        border-width: 1px;
                        clip: true;

                        sl-add-input := TextInput {
                            width: max(parent.width - 16px, self.preferred-width);
                            x: 8px;
                            vertical-alignment: center;
                            color: Theme.c.text;
                            font-size: 13px;

                            accepted => {
                                if self.text != "" {
                                    item-added(self.text);
                                    self.text = "";
                                }
                            }
                        }

                        if sl-add-input.text == "": Text {
                            x: 8px;
                            text: "add new entry...";
                            color: Theme.c.overlay0;
                            font-size: 13px;
                            vertical-alignment: center;
                        }

                        init => { sl-add-input.focus(); }
                    }

                    Rectangle {
                        width: 60px;
                        height: 34px;
                        background: sl-add-ta.has-hover ? Theme.c.sky : Theme.c.blue;
                        border-radius: 4px;

                        sl-add-ta := TouchArea {
                            clicked => {
                                if sl-add-input.text != "" {
                                    item-added(sl-add-input.text);
                                    sl-add-input.text = "";
                                    sl-add-input.focus();
                                }
                            }
                        }

                        Text {
                            text: "Add";
                            color: Theme.c.base;
                            font-size: 13px;
                            font-weight: FontWeight.semi-bold;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }

                // Done button
                HorizontalLayout {
                    alignment: end;

                    Rectangle {
                        width: 80px;
                        height: 30px;
                        background: sl-done-ta.has-hover ? Theme.c.surface1 : Theme.c.surface0;
                        border-radius: 4px;

                        sl-done-ta := TouchArea {
                            clicked => { closed(); }
                        }

                        Text {
                            text: "Done";
                            color: Theme.c.subtext0;
                            font-size: 13px;
                            font-weight: FontWeight.semi-bold;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }
}

// ── Package search popup ─────────────────────────────

component PackageSearchPopup inherits Rectangle {
    in property <[PackageSearchResult]> search-results;
    in property <[PackageEntry]> selected-packages;
    in property <bool> popup-visible;
    in property <bool> searching-aur: false;
    in property <string> status-text;

    callback search-changed(string);  // fired on each keystroke
    callback search-aur(string);      // fired on Tab
    callback package-added(int);      // index in search-results
    callback package-removed(int);    // index in selected-packages
    callback closed();

    if popup-visible: Rectangle {
        background: #00000080;
        width: 100%; height: 100%;

        TouchArea { clicked => { closed(); } }

        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: min(600px, parent.width - 40px);
            height: min(parent.height - 60px, 520px);
            background: Theme.c.mantle;
            border-radius: 8px;
            border-color: Theme.c.surface1;
            border-width: 1px;
            clip: true;
            accessible-role: groupbox;
            accessible-label: "Package search";

            VerticalLayout {
                padding: 16px;
                spacing: 10px;

                // Title
                Text {
                    text: searching-aur ? "AUR search" : "Package search";
                    color: Theme.c.blue;
                    font-size: 16px;
                    font-weight: FontWeight.semi-bold;
                }

                // Search input + AUR button
                HorizontalLayout {
                    spacing: 8px;

                    Rectangle {
                        horizontal-stretch: 1;
                        height: 36px;
                        background: Theme.c.surface0;
                        border-radius: 4px;
                        border-color: pkg-search-input.has-focus ? Theme.c.blue : Theme.c.surface1;
                        border-width: 1px;
                        clip: true;

                        pkg-search-input := TextInput {
                            width: max(parent.width - 16px, self.preferred-width);
                            x: 8px;
                            vertical-alignment: center;
                            color: Theme.c.text;
                            font-size: 14px;

                            private property <length> margin: 8px;
                            cursor-position-changed(cursor-position) => {
                                if cursor-position.x + self.x < margin {
                                    self.x = - cursor-position.x + margin;
                                } else if cursor-position.x + self.x > parent.width - margin - self.text-cursor-width {
                                    self.x = parent.width - cursor-position.x - margin - self.text-cursor-width;
                                }
                            }

                            edited => {
                                search-changed(self.text);
                            }
                        }

                        // Placeholder
                        if pkg-search-input.text == "": Text {
                            x: 8px;
                            text: "type to search packages...";
                            color: Theme.c.overlay0;
                            font-size: 14px;
                            vertical-alignment: center;
                        }

                        init => { pkg-search-input.focus(); }
                    }

                    // AUR search button
                    Rectangle {
                        width: 60px;
                        height: 36px;
                        background: aur-btn-ta.has-hover ? Theme.c.mauve : Theme.c.surface0;
                        border-radius: 4px;
                        border-color: searching-aur ? Theme.c.mauve : Theme.c.surface1;
                        border-width: 1px;

                        aur-btn-ta := TouchArea {
                            clicked => {
                                search-aur(pkg-search-input.text);
                            }
                        }

                        Text {
                            text: "AUR";
                            color: aur-btn-ta.has-hover ? Theme.c.base : (searching-aur ? Theme.c.mauve : Theme.c.subtext0);
                            font-size: 13px;
                            font-weight: FontWeight.semi-bold;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }

                // Status / hint
                if status-text != "": Text {
                    text: status-text;
                    color: Theme.c.overlay0;
                    font-size: 12px;
                    height: 16px;
                }

                // Search results
                ListView {
                    vertical-stretch: 1;

                    for result[index] in search-results: Rectangle {
                        height: 36px;
                        background: result-ta.has-hover ? Theme.c.surface1 : Theme.c.surface0;
                        border-radius: 4px;

                        result-ta := TouchArea {
                            clicked => {
                                package-added(index);
                                pkg-search-input.text = "";
                                pkg-search-input.focus();
                            }
                        }

                        HorizontalLayout {
                            padding-left: 12px;
                            padding-right: 12px;
                            spacing: 8px;

                            Text {
                                text: result.name;
                                color: Theme.c.text;
                                font-size: 13px;
                                vertical-alignment: center;
                            }

                            // Repo badge
                            Rectangle {
                                width: repo-badge-text.preferred-width + 10px;
                                height: 18px;
                                background: result.repo == "aur" ? Theme.c.mauve : Theme.c.blue;
                                border-radius: 3px;

                                repo-badge-text := Text {
                                    text: result.repo;
                                    color: Theme.c.base;
                                    font-size: 10px;
                                    font-weight: FontWeight.semi-bold;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }

                            Text {
                                text: result.description;
                                color: Theme.c.overlay0;
                                font-size: 12px;
                                vertical-alignment: center;
                                overflow: elide;
                                horizontal-stretch: 1;
                            }
                        }
                    }
                }

                // Separator
                if selected-packages.length > 0: Rectangle {
                    height: 1px;
                    background: Theme.c.surface1;
                }

                // Selected packages
                if selected-packages.length > 0: VerticalLayout {
                    spacing: 4px;
                    height: min(self.preferred-height, 100px);

                    Text {
                        text: "Selected";
                        color: Theme.c.subtext0;
                        font-size: 12px;
                        font-weight: FontWeight.semi-bold;
                        height: 16px;
                    }

                    Flickable {
                        HorizontalLayout {
                            spacing: 6px;
                            alignment: start;

                            for pkg[index] in selected-packages: Rectangle {
                                width: pkg-chip-layout.preferred-width;
                                height: 26px;
                                background: pkg-del-ta.has-hover ? Theme.c.red : Theme.c.surface0;
                                border-radius: 4px;

                                pkg-del-ta := TouchArea {
                                    clicked => { package-removed(index); }
                                }

                                pkg-chip-layout := HorizontalLayout {
                                    padding-left: 8px;
                                    padding-right: 8px;
                                    spacing: 4px;

                                    Text {
                                        text: pkg.name;
                                        color: pkg-del-ta.has-hover ? Theme.c.base : Theme.c.text;
                                        font-size: 12px;
                                        vertical-alignment: center;
                                    }

                                    Text {
                                        text: pkg.repo == "aur" ? "[aur]" : "[repo]";
                                        color: pkg-del-ta.has-hover ? Theme.c.base : Theme.c.overlay0;
                                        font-size: 10px;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }
                }

                // Done button
                HorizontalLayout {
                    alignment: end;

                    Rectangle {
                        width: 80px;
                        height: 30px;
                        background: pkg-done-ta.has-hover ? Theme.c.sky : Theme.c.blue;
                        border-radius: 4px;

                        pkg-done-ta := TouchArea {
                            clicked => { closed(); }
                        }

                        Text {
                            text: "Done";
                            color: Theme.c.base;
                            font-size: 13px;
                            font-weight: FontWeight.semi-bold;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }
}

// ── Sidebar step item ────────────────────────────────

component SidebarItem inherits Rectangle {
    in property <string> label;
    in property <int> state; // 0=pending, 1=current, 2=done
    in property <int> step-index;

    callback clicked();

    accessible-role: button;
    accessible-label: label;
    accessible-enabled: state == 1 || state == 2;

    height: 36px;
    background: state == 1 ? Theme.c.surface0
              : step-ta.has-hover && state == 2 ? Theme.c.surface0
              : transparent;
    border-radius: 4px;

    step-ta := TouchArea {
        mouse-cursor: state == 2 ? pointer : default;
        clicked => {
            if state == 2 || state == 1 {
                root.clicked();
            }
        }
    }

    HorizontalLayout {
        padding-left: 12px;
        spacing: 8px;
        alignment: start;

        Text {
            text: state == 1 ? "\u{25b8}"  // ▸
                : state == 2 ? "\u{25cf}"   // ●
                : "\u{25cb}";               // ○
            color: state == 1 ? Theme.c.blue
                 : state == 2 ? Theme.c.green
                 : Theme.c.overlay0;
            font-size: 14px;
            vertical-alignment: center;
            width: 16px;
        }

        Text {
            text: label;
            color: state == 1 ? Theme.c.blue
                 : state == 2 ? Theme.c.green
                 : Theme.c.overlay0;
            font-size: 14px;
            font-weight: state == 1 ? FontWeight.semi-bold : FontWeight.normal;
            vertical-alignment: center;
        }
    }
}

// ── Main application ─────────────────────────────────

export component App inherits Window {
    background: Theme.c.base;
    preferred-width: 800px;
    preferred-height: 600px;
    title: "archinstall-zfs";
    forward-focus: main-focus-scope;

    // Wizard state
    in property <[StepInfo]> steps;
    in property <int> current-step: 0;
    in property <int> total-steps: 7;

    // Welcome screen status
    in property <bool> net-ok: false;
    in property <bool> uefi-ok: false;
    in property <bool> zfs-ok: false;
    in property <bool> zfs-installing: false;
    in property <int> zfs-install-pct: 0;
    in property <string> zfs-install-status: "";

    callback check-internet();
    callback start-wizard();

    // Config items model (per-step)
    // item-type: 0=text, 1=select(popup), 2=password, 3=toggle, 4=separator,
    //            5=action, 6=readonly, 7=warning, 8=radio-header, 9=radio-option
    in property <[ConfigItem]> config-items;

    // Select popup state
    in-out property <bool> select-visible: false;
    in-out property <string> select-title;
    in-out property <[SelectOption]> select-options;
    in-out property <int> select-index;
    in-out property <string> select-key;
    in-out property <bool> select-show-filter: false;

    // Text input popup state
    in-out property <bool> text-input-visible: false;
    in-out property <string> text-input-title;
    in-out property <string> text-input-value;
    in-out property <bool> text-input-password: false;
    in-out property <string> text-input-key;

    // Password strength (driven from Rust)
    in-out property <int> password-strength-score: -1;
    in-out property <string> password-strength-label;
    in-out property <string> password-strength-hint;
    in-out property <color> password-strength-color: Theme.c.overlay0;

    // User management popup state
    in-out property <bool> users-visible: false;
    in property <[UserEntry]> users-list;

    // String list popup state
    in-out property <bool> strlist-visible: false;
    in-out property <string> strlist-title;
    in-out property <string> strlist-key;
    in property <[SelectOption]> strlist-items;

    callback strlist-added(string, string); // key, value
    callback strlist-removed(string, int);  // key, index

    // Package search popup state
    in-out property <bool> pkg-search-visible: false;
    in property <[PackageSearchResult]> pkg-search-results;
    in property <[PackageEntry]> pkg-selected;
    in-out property <bool> pkg-searching-aur: false;
    in-out property <string> pkg-status-text;

    callback pkg-search-changed(string);
    callback pkg-search-aur(string);
    callback pkg-added(int);
    callback pkg-removed(int);

    // Install state: 0=config, 1=installing, 2=done, 3=failed
    in-out property <int> install-state: 0;

    // Log messages
    in property <[LogMessage]> log-messages;

    // Global install progress
    in property <string> install-phase-label: "Starting...";
    in property <int> install-phase: 0;
    in property <int> install-total-phases: 14;

    // Package download/install progress
    in property <[DownloadInfo]> download-items;
    in property <int> download-pct: 0;
    in property <string> download-status: "";
    in property <bool> download-active: false;

    // Status text
    in property <string> status-text;

    // Keyboard-driven focus index (-1 = none)
    in-out property <int> focused-index: -1;

    // Callbacks to Rust
    callback item-activated(string);
    callback select-confirmed(string, int);
    callback select-filter-changed(string, string); // (select-key, filter-text)
    callback text-confirmed(string, string);
    callback text-input-edited(string, string); // (text-input-key, current-text)
    callback toggle-activated(string);
    callback install-requested();
    callback quit-requested();
    callback step-clicked(int);
    callback user-added(string, string, bool); // username, password, sudo
    callback user-removed(int);
    callback user-sudo-toggled(int);
    callback next-step();
    callback prev-step();
    callback key-nav-down();
    callback key-nav-up();
    callback key-nav-activate();

    // ── Keyboard navigation ─────────────────────────
    main-focus-scope := FocusScope {
        enabled: install-state == 0 && !select-visible && !text-input-visible && !users-visible && !pkg-search-visible && !strlist-visible;
        key-pressed(e) => {
            if e.text == Key.DownArrow || e.text == "j" {
                key-nav-down();
                return accept;
            }
            if e.text == Key.UpArrow || e.text == "k" {
                key-nav-up();
                return accept;
            }
            if e.text == Key.Return {
                key-nav-activate();
                return accept;
            }
            if e.text == Key.Tab {
                next-step();
                return accept;
            }
            if e.text == Key.Backtab {
                prev-step();
                return accept;
            }
            if e.text == "q" {
                quit-requested();
                return accept;
            }
            if e.text == "1" { step-clicked(0); return accept; }
            if e.text == "2" { step-clicked(1); return accept; }
            if e.text == "3" { step-clicked(2); return accept; }
            if e.text == "4" { step-clicked(3); return accept; }
            if e.text == "5" { step-clicked(4); return accept; }
            if e.text == "6" { step-clicked(5); return accept; }
            if e.text == "7" { step-clicked(6); return accept; }
            return reject;
        }
    }

    // ── Welcome screen (step 0, no sidebar) ───────────
    if install-state == 0 && current-step == 0: Rectangle {
        background: Theme.c.base;

        VerticalLayout {
            alignment: center;
            spacing: 0px;

            // Centered content block
            HorizontalLayout {
                alignment: center;

                VerticalLayout {
                    width: min(500px, root.width - 60px);
                    spacing: 24px;
                    alignment: center;

                    // Title
                    VerticalLayout {
                        spacing: 8px;

                        Text {
                            text: "archinstall-zfs";
                            color: Theme.c.blue;
                            font-size: 36px;
                            font-weight: FontWeight.bold;
                            horizontal-alignment: center;
                        }

                        Text {
                            text: "Arch Linux installer with ZFS root";
                            color: Theme.c.subtext0;
                            font-size: 16px;
                            horizontal-alignment: center;
                        }
                    }

                    // Status cards
                    VerticalLayout {
                        spacing: 8px;

                        // Network status
                        Rectangle {
                            height: 48px;
                            background: Theme.c.surface0;
                            border-radius: 10px;

                            HorizontalLayout {
                                padding-left: 16px;
                                padding-right: 12px;
                                spacing: 12px;

                                Text {
                                    text: net-ok ? "\u{2713}" : "\u{2717}";
                                    color: net-ok ? Theme.c.green : Theme.c.red;
                                    font-size: 18px;
                                    vertical-alignment: center;
                                    width: 24px;
                                }

                                Text {
                                    text: "Internet connection";
                                    color: Theme.c.text;
                                    font-size: 14px;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                }

                                Text {
                                    text: net-ok ? "Connected" : "Not connected";
                                    color: net-ok ? Theme.c.green : Theme.c.overlay0;
                                    font-size: 13px;
                                    vertical-alignment: center;
                                }

                                if !net-ok: Rectangle {
                                    width: 90px;
                                    height: 30px;
                                    background: check-net-ta.has-hover ? Theme.c.surface1 : Theme.c.mantle;
                                    border-radius: 6px;

                                    check-net-ta := TouchArea {
                                        clicked => { check-internet(); }
                                    }

                                    Text {
                                        text: "Check again";
                                        color: Theme.c.blue;
                                        font-size: 12px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }

                        // UEFI status
                        Rectangle {
                            height: 48px;
                            background: Theme.c.surface0;
                            border-radius: 10px;

                            HorizontalLayout {
                                padding-left: 16px;
                                padding-right: 16px;
                                spacing: 12px;

                                Text {
                                    text: uefi-ok ? "\u{2713}" : "\u{2717}";
                                    color: uefi-ok ? Theme.c.green : Theme.c.red;
                                    font-size: 18px;
                                    vertical-alignment: center;
                                    width: 24px;
                                }

                                Text {
                                    text: "UEFI boot mode";
                                    color: Theme.c.text;
                                    font-size: 14px;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                }

                                Text {
                                    text: uefi-ok ? "Detected" : "Not detected (required)";
                                    color: uefi-ok ? Theme.c.green : Theme.c.red;
                                    font-size: 13px;
                                    vertical-alignment: center;
                                }
                            }
                        }

                        // ZFS status
                        Rectangle {
                            height: zfs-installing ? 72px : 48px;
                            background: Theme.c.surface0;
                            border-radius: 10px;

                            VerticalLayout {
                                padding: 0px;
                                spacing: 0px;

                                HorizontalLayout {
                                    height: 48px;
                                    padding-left: 16px;
                                    padding-right: 16px;
                                    spacing: 12px;

                                    Text {
                                        text: zfs-ok ? "\u{2713}"
                                            : zfs-installing ? "\u{21bb}"
                                            : "\u{2717}";
                                        color: zfs-ok ? Theme.c.green
                                            : zfs-installing ? Theme.c.blue
                                            : Theme.c.overlay0;
                                        font-size: 18px;
                                        vertical-alignment: center;
                                        width: 24px;
                                    }

                                    Text {
                                        text: "ZFS support";
                                        color: Theme.c.text;
                                        font-size: 14px;
                                        vertical-alignment: center;
                                        horizontal-stretch: 1;
                                    }

                                    Text {
                                        text: zfs-ok ? "Ready"
                                            : zfs-installing ? zfs-install-status
                                            : "Waiting for network...";
                                        color: zfs-ok ? Theme.c.green
                                            : zfs-installing ? Theme.c.blue
                                            : Theme.c.overlay0;
                                        font-size: 13px;
                                        vertical-alignment: center;
                                    }
                                }

                                // ZFS install progress bar
                                if zfs-installing: Rectangle {
                                    height: 6px;
                                    x: 16px;
                                    width: parent.width - 32px;
                                    background: Theme.c.mantle;
                                    border-radius: 3px;
                                    clip: true;

                                    Rectangle {
                                        x: 0; y: 0;
                                        height: parent.height;
                                        width: parent.width * zfs-install-pct / 100;
                                        background: Theme.c.blue;
                                        border-radius: 3px;
                                    }
                                }

                                // spacer at bottom when installing
                                if zfs-installing: Rectangle {
                                    height: 12px;
                                }
                            }
                        }
                    }

                    // Start button
                    HorizontalLayout {
                        alignment: center;

                        Rectangle {
                            width: 160px;
                            height: 44px;
                            background: net-ok && uefi-ok && zfs-ok
                                ? (start-ta.has-hover ? Theme.c.sky : Theme.c.blue)
                                : Theme.c.surface1;
                            border-radius: 10px;

                            start-ta := TouchArea {
                                enabled: net-ok && uefi-ok && zfs-ok;
                                mouse-cursor: self.enabled ? pointer : default;
                                clicked => { start-wizard(); }
                            }

                            Text {
                                text: "Get Started \u{2192}";
                                color: net-ok && uefi-ok && zfs-ok
                                    ? Theme.c.base : Theme.c.overlay0;
                                font-size: 15px;
                                font-weight: FontWeight.semi-bold;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }

                    // Version
                    Text {
                        text: "v0.1.0";
                        color: Theme.c.overlay0;
                        font-size: 11px;
                        horizontal-alignment: center;
                    }
                }
            }
        }
    }

    // ── Wizard config screen (steps 1+, with sidebar) ──
    if install-state == 0 && current-step > 0: VerticalLayout {
        padding: 0px;
        spacing: 0px;

        // Title bar
        Rectangle {
            height: 48px;
            background: Theme.c.mantle;

            HorizontalLayout {
                padding-left: 16px;
                padding-right: 16px;

                Text {
                    text: "archinstall-zfs";
                    color: Theme.c.blue;
                    font-size: 22px;
                    font-weight: FontWeight.bold;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }

                Text {
                    text: current-step + " / " + (total-steps - 1);
                    color: Theme.c.overlay0;
                    font-size: 14px;
                    vertical-alignment: center;
                }
            }
        }

        // Body: sidebar + content
        HorizontalLayout {
            spacing: 0px;

            // Sidebar (skip Welcome in sidebar, show steps 1-6)
            Rectangle {
                width: 140px;
                background: Theme.c.mantle;

                VerticalLayout {
                    padding: 8px;
                    spacing: 2px;
                    alignment: start;

                    for step[index] in steps: SidebarItem {
                        visible: index > 0;
                        label: step.label;
                        state: step.state;
                        step-index: index;

                        clicked => {
                            step-clicked(index);
                        }
                    }
                }
            }

            // Vertical separator
            Rectangle {
                width: 1px;
                background: Theme.c.surface1;
            }

            // Content area
            VerticalLayout {
                spacing: 0px;

                // Step title
                Rectangle {
                    height: 40px;
                    background: transparent;

                    HorizontalLayout {
                        padding-left: 16px;
                        alignment: start;

                        Text {
                            text: steps.length > 0 && current-step < steps.length
                                ? steps[current-step].label : "";
                            color: Theme.c.mauve;
                            font-size: 18px;
                            font-weight: FontWeight.semi-bold;
                            vertical-alignment: center;
                        }
                    }
                }

                // Config items list — card-based design
                ScrollView {
                    VerticalLayout {
                        spacing: 2px;
                        padding: 8px;
                        padding-left: 12px;
                        padding-right: 12px;

                        for item[index] in config-items: Rectangle {
                            // Heights
                            height: item.item-type == 4 ? 12px      // separator gap
                                  : item.item-type == 7 ? 32px      // warning
                                  : item.item-type == 8 ? 36px      // radio card header
                                  : item.item-type == 9 ? 36px      // radio option
                                  : item.item-type == 5 ? 40px      // action button
                                  : 44px;                           // normal items

                            // Card backgrounds
                            border-radius: item.item-type == 8 ? 8px    // radio header: top corners only visually
                                         : item.item-type == 4 ? 0px
                                         : item.item-type == 7 ? 6px
                                         : 8px;

                            background: item.item-type == 4 ? transparent
                                      : item.item-type == 8 ? Theme.c.surface0  // radio header = card top
                                      : item.item-type == 9 ? Theme.c.surface0  // radio body = card body
                                      : item.item-type == 7 ? transparent
                                      : item.item-type == 5 ? transparent       // actions = no card bg
                                      : item.item-type == 6 ? Theme.c.surface0  // readonly = card
                                      : Theme.c.surface0;                       // normal items = card

                            // Hover highlight
                            Rectangle {
                                visible: (row-ta.has-hover || index == focused-index)
                                    && item.item-type != 4
                                    && item.item-type != 6
                                    && item.item-type != 7
                                    && item.item-type != 8;
                                background: #ffffff10;
                                border-radius: parent.border-radius;
                            }

                            // ── Separator ──
                            if item.item-type == 4: Rectangle { }

                            // ── Warning ──
                            if item.item-type == 7: HorizontalLayout {
                                padding-left: 12px;
                                spacing: 8px;
                                alignment: start;

                                Text {
                                    text: "\u{26a0}";
                                    color: Theme.c.yellow;
                                    font-size: 14px;
                                    vertical-alignment: center;
                                }
                                Text {
                                    text: item.value;
                                    color: Theme.c.yellow;
                                    font-size: 13px;
                                    vertical-alignment: center;
                                }
                            }

                            // ── Radio group header (card title bar) ──
                            if item.item-type == 8: HorizontalLayout {
                                padding-left: 14px;
                                alignment: start;

                                Text {
                                    text: item.label;
                                    color: Theme.c.blue;
                                    font-size: 13px;
                                    font-weight: FontWeight.semi-bold;
                                    vertical-alignment: center;
                                }
                            }

                            // ── Radio option (card body row) ──
                            if item.item-type == 9: HorizontalLayout {
                                padding-left: 14px;
                                padding-right: 14px;
                                spacing: 10px;
                                alignment: start;

                                Text {
                                    text: item.value == "selected" ? "\u{25cf}" : "\u{25cb}";
                                    color: item.value == "selected" ? Theme.c.green : Theme.c.overlay0;
                                    font-size: 16px;
                                    vertical-alignment: center;
                                    width: 18px;
                                }

                                Text {
                                    text: item.label;
                                    color: item.value == "selected" ? Theme.c.text : Theme.c.subtext0;
                                    font-size: 14px;
                                    vertical-alignment: center;
                                }
                            }

                            // ── Action button ──
                            if item.item-type == 5: Rectangle {
                                background: item.key == "install" ? Theme.c.blue : Theme.c.surface0;
                                border-radius: 8px;

                                Rectangle {
                                    visible: row-ta.has-hover || index == focused-index;
                                    background: #ffffff18;
                                    border-radius: parent.border-radius;
                                }

                                Text {
                                    text: item.label;
                                    color: item.key == "install" ? Theme.c.base : Theme.c.text;
                                    font-size: 14px;
                                    font-weight: FontWeight.semi-bold;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }

                            // ── Read-only summary (review step) ──
                            if item.item-type == 6: HorizontalLayout {
                                padding-left: 14px;
                                padding-right: 14px;

                                Text {
                                    text: item.label;
                                    color: Theme.c.subtext0;
                                    font-size: 13px;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                }

                                Text {
                                    text: item.value;
                                    color: item.value == "Not set" || item.value == "None" || item.value == "Disabled"
                                        ? Theme.c.overlay0
                                        : Theme.c.green;
                                    font-size: 13px;
                                    vertical-alignment: center;
                                }
                            }

                            // ── Normal config items (text, select, password, toggle) ──
                            if item.item-type == 0 || item.item-type == 1
                                || item.item-type == 2 || item.item-type == 3: HorizontalLayout {
                                padding-left: 14px;
                                padding-right: 14px;

                                Text {
                                    text: item.label;
                                    color: Theme.c.subtext1;
                                    font-size: 14px;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                }

                                // Type indicator + value
                                HorizontalLayout {
                                    spacing: 6px;
                                    alignment: end;

                                    // Toggle indicator
                                    if item.item-type == 3: Text {
                                        text: item.value == "Enabled" ? "\u{25cf}" : "\u{25cb}";
                                        color: item.value == "Enabled" ? Theme.c.green : Theme.c.overlay0;
                                        font-size: 14px;
                                        vertical-alignment: center;
                                    }

                                    Text {
                                        text: item.value;
                                        color: item.value == "Not set" || item.value == "None" || item.value == "Disabled"
                                            ? Theme.c.overlay0
                                            : Theme.c.green;
                                        font-size: 14px;
                                        vertical-alignment: center;
                                    }
                                }
                            }

                            // ── Touch area (for all item types) ──
                            row-ta := TouchArea {
                                mouse-cursor: item.item-type == 4 || item.item-type == 6
                                    || item.item-type == 7 || item.item-type == 8
                                    ? default : pointer;
                                clicked => {
                                    focused-index = index;
                                    if item.item-type == 5 {
                                        if item.key == "install" { install-requested(); }
                                        if item.key == "quit" { quit-requested(); }
                                    } else if item.item-type == 3 {
                                        toggle-activated(item.key);
                                    } else if item.item-type != 4
                                           && item.item-type != 6
                                           && item.item-type != 7
                                           && item.item-type != 8 {
                                        item-activated(item.key);
                                    }
                                }
                            }
                        }
                    }
                }

                // Footer with navigation buttons
                Rectangle {
                    height: 44px;
                    background: Theme.c.mantle;

                    HorizontalLayout {
                        padding-left: 16px;
                        padding-right: 16px;
                        spacing: 8px;
                        alignment: center;

                        // Quit button
                        Rectangle {
                            width: 60px;
                            height: 32px;
                            background: quit-nav-ta.has-hover ? Theme.c.surface1 : transparent;
                            border-radius: 4px;

                            quit-nav-ta := TouchArea {
                                clicked => { quit-requested(); }
                            }

                            Text {
                                text: "Quit";
                                color: Theme.c.overlay0;
                                font-size: 13px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }

                        // Back button (not on first wizard step)
                        if current-step > 1: Rectangle {
                            width: 80px;
                            height: 32px;
                            background: back-ta.has-hover ? Theme.c.surface1 : Theme.c.surface0;
                            border-radius: 4px;

                            back-ta := TouchArea {
                                clicked => { prev-step(); }
                            }

                            Text {
                                text: "\u{25c2} Back";
                                color: Theme.c.subtext0;
                                font-size: 13px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }

                        // Status text
                        Text {
                            text: status-text;
                            color: Theme.c.overlay0;
                            font-size: 12px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }

                        // Next button
                        if current-step < total-steps - 1: Rectangle {
                            width: 80px;
                            height: 32px;
                            background: next-ta.has-hover ? Theme.c.sky : Theme.c.blue;
                            border-radius: 4px;

                            next-ta := TouchArea {
                                clicked => { next-step(); }
                            }

                            Text {
                                text: "Next \u{25b8}";
                                color: Theme.c.base;
                                font-size: 13px;
                                font-weight: FontWeight.semi-bold;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }
        }
    }

    // ── Install progress screen ──────────────────────
    if install-state >= 1: VerticalLayout {
        padding: 12px;
        spacing: 8px;

        // ── Log area (fills available space) ────────
        log-view := ListView {
            for msg[index] in log-messages: Rectangle {
                height: msg-text.preferred-height + 4px;

                msg-text := Text {
                    text: msg.text;
                    color: msg.level == 4 ? Theme.c.red
                         : msg.level == 3 ? Theme.c.yellow
                         : msg.level == 2 ? Theme.c.green
                         : msg.level == 1 ? Theme.c.blue
                         : Theme.c.overlay0;
                    font-family: "monospace";
                    font-size: 12px;
                    x: 8px;
                    width: parent.width - 16px;
                    wrap: word-wrap;
                    vertical-alignment: center;
                }
            }
        }

        property <int> scroll-trigger: log-messages.length;
        changed scroll-trigger => {
            log-view.viewport-y = -100000px;
        }

        // ── Progress card (always visible during install) ──
        Rectangle {
            height: download-active ? 180px : 80px;
            background: Theme.c.surface0;
            border-radius: 10px;

            VerticalLayout {
                padding: 14px;
                spacing: 8px;

                // Global phase status
                HorizontalLayout {
                    spacing: 10px;

                    Text {
                        text: install-state == 2 ? "\u{2713} Complete"
                            : install-state == 3 ? "\u{2717} Failed"
                            : install-phase-label;
                        color: install-state == 2 ? Theme.c.green
                            : install-state == 3 ? Theme.c.red
                            : Theme.c.text;
                        font-size: 14px;
                        font-weight: FontWeight.semi-bold;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                    }

                    Text {
                        text: install-state >= 2 ? ""
                            : install-phase + " / " + install-total-phases;
                        color: Theme.c.overlay0;
                        font-size: 13px;
                        vertical-alignment: center;
                    }
                }

                // Global progress bar
                if install-state == 1: Rectangle {
                    height: 8px;
                    background: Theme.c.mantle;
                    border-radius: 4px;
                    clip: true;

                    Rectangle {
                        x: 0; y: 0;
                        height: parent.height;
                        width: parent.width * install-phase / install-total-phases;
                        background: Theme.c.blue;
                        border-radius: 4px;
                    }
                }

                // Package progress (download or install)
                if download-active: VerticalLayout {
                    spacing: 6px;

                    // Download/install status line
                    HorizontalLayout {
                        Text {
                            text: download-status;
                            color: Theme.c.teal;
                            font-size: 12px;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }

                        Text {
                            text: download-pct + "%";
                            color: Theme.c.teal;
                            font-size: 12px;
                            font-weight: FontWeight.semi-bold;
                            vertical-alignment: center;
                        }
                    }

                    // Package progress bar
                    Rectangle {
                        height: 6px;
                        background: Theme.c.mantle;
                        border-radius: 3px;
                        clip: true;

                        Rectangle {
                            x: 0; y: 0;
                            height: parent.height;
                            width: parent.width * download-pct / 100;
                            background: Theme.c.teal;
                            border-radius: 3px;
                        }
                    }

                    // Per-package lines
                    ListView {
                        for dl[index] in download-items: Rectangle {
                            height: 18px;

                            HorizontalLayout {
                                padding-left: 4px;
                                padding-right: 4px;
                                spacing: 8px;

                                Text {
                                    text: dl.filename;
                                    color: dl.state == 1 ? Theme.c.overlay0
                                         : dl.state == 2 ? Theme.c.green
                                         : Theme.c.text;
                                    font-size: 11px;
                                    font-family: "monospace";
                                    overflow: elide;
                                    horizontal-stretch: 1;
                                    vertical-alignment: center;
                                }

                                Text {
                                    text: dl.state == 1 ? "verifying..."
                                         : dl.state == 2 ? "done"
                                         : dl.pct + "% " + dl.speed;
                                    color: dl.state == 2 ? Theme.c.green : Theme.c.overlay0;
                                    font-size: 11px;
                                    font-family: "monospace";
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }
                }

                // Exit button
                if install-state >= 2: Rectangle {
                    height: 36px;
                    background: exit-ta.has-hover ? Theme.c.blue : Theme.c.surface1;
                    border-radius: 8px;

                    exit-ta := TouchArea {
                        clicked => { quit-requested(); }
                    }

                    Text {
                        text: install-state == 2 ? "Reboot" : "Exit";
                        color: exit-ta.has-hover ? Theme.c.base : Theme.c.text;
                        font-size: 14px;
                        font-weight: FontWeight.semi-bold;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }

    // ── Popup overlays ──────────────────────────────────

    SelectPopup {
        title: select-title;
        options: select-options;
        selected-index: select-index;
        popup-visible: select-visible;
        show-filter: select-show-filter;

        accepted(idx) => {
            select-visible = false;
            select-confirmed(select-key, idx);
        }
        cancelled() => {
            select-visible = false;
        }
        filter-changed(text) => {
            select-filter-changed(select-key, text);
        }
    }

    TextInputPopup {
        title: text-input-title;
        input-text: text-input-value;
        is-password: text-input-password;
        popup-visible: text-input-visible;
        strength-score: password-strength-score;
        strength-label: password-strength-label;
        strength-hint: password-strength-hint;
        strength-color: password-strength-color;

        confirmed(val) => {
            text-input-visible = false;
            text-confirmed(text-input-key, val);
        }
        cancelled() => {
            text-input-visible = false;
        }
        text-edited(val) => {
            text-input-edited(text-input-key, val);
        }
    }

    UserManagePopup {
        users: users-list;
        popup-visible: users-visible;

        user-added(username, password, sudo) => {
            root.user-added(username, password, sudo);
        }
        user-removed(index) => {
            root.user-removed(index);
        }
        user-sudo-toggled(index) => {
            root.user-sudo-toggled(index);
        }
        closed() => {
            users-visible = false;
        }
    }

    StringListPopup {
        title: strlist-title;
        items: strlist-items;
        popup-visible: strlist-visible;

        item-added(val) => {
            strlist-added(strlist-key, val);
        }
        item-removed(index) => {
            strlist-removed(strlist-key, index);
        }
        closed() => {
            strlist-visible = false;
        }
    }

    PackageSearchPopup {
        search-results: pkg-search-results;
        selected-packages: pkg-selected;
        popup-visible: pkg-search-visible;
        searching-aur: pkg-searching-aur;
        status-text: pkg-status-text;

        search-changed(text) => {
            root.pkg-search-changed(text);
        }
        search-aur(text) => {
            root.pkg-search-aur(text);
        }
        package-added(index) => {
            root.pkg-added(index);
        }
        package-removed(index) => {
            root.pkg-removed(index);
        }
        closed() => {
            pkg-search-visible = false;
        }
    }
}
