import { ListView, ScrollView } from "std-widgets.slint";

// Catppuccin Mocha color palette
struct Catppuccin {
    base: color,
    mantle: color,
    surface0: color,
    surface1: color,
    overlay0: color,
    text: color,
    subtext0: color,
    subtext1: color,
    blue: color,
    green: color,
    red: color,
    yellow: color,
    mauve: color,
    teal: color,
    sky: color,
    peach: color,
}

global Theme {
    out property <Catppuccin> c: {
        base: #1e1e2e,
        mantle: #181825,
        surface0: #313244,
        surface1: #45475a,
        overlay0: #6c7086,
        text: #cdd6f4,
        subtext0: #a6adc8,
        subtext1: #bac2de,
        blue: #89b4fa,
        green: #a6e3a1,
        red: #f38ba8,
        yellow: #f9e2af,
        mauve: #cba6f7,
        teal: #94e2d5,
        sky: #89dceb,
        peach: #fab387,
    };
}

export struct ConfigItem {
    key: string,
    label: string,
    value: string,
    item-type: int, // 0=text, 1=select, 2=password, 3=toggle, 4=separator, 5=action, 6=readonly, 7=warning
}

export struct SelectOption {
    text: string,
}

export struct LogMessage {
    text: string,
    level: int,
}

export struct DownloadInfo {
    filename: string,
    pct: int,
    speed: string,
    state: int, // 0=downloading, 1=verifying, 2=done
}

export struct StepInfo {
    label: string,
    state: int, // 0=pending, 1=current, 2=done
}

// ── Text input popup ─────────────────────────────────

component TextInputPopup inherits Rectangle {
    in property <string> title;
    in-out property <string> input-text;
    in property <bool> is-password: false;
    in property <bool> popup-visible;

    callback confirmed(string);
    callback cancelled();

    if popup-visible: Rectangle {
        background: #00000080;
        width: 100%; height: 100%;

        TouchArea { clicked => { cancelled(); } }

        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: min(500px, parent.width - 40px);
            height: 140px;
            background: Theme.c.mantle;
            border-radius: 8px;
            border-color: Theme.c.surface1;
            border-width: 1px;

            VerticalLayout {
                padding: 16px;
                spacing: 12px;

                Text {
                    text: title;
                    color: Theme.c.blue;
                    font-size: 16px;
                    font-weight: 600;
                }

                Rectangle {
                    height: 36px;
                    background: Theme.c.surface0;
                    border-radius: 4px;
                    border-color: Theme.c.blue;
                    border-width: 1px;

                    input := TextInput {
                        x: 8px;
                        width: parent.width - 16px;
                        vertical-alignment: center;
                        color: Theme.c.text;
                        font-size: 14px;
                        text: input-text;
                        input-type: is-password ? InputType.password : InputType.text;

                        accepted => {
                            confirmed(self.text);
                        }
                    }
                }

                HorizontalLayout {
                    spacing: 8px;
                    alignment: end;

                    Rectangle {
                        width: 80px;
                        height: 30px;
                        background: cancel-ta.has-hover ? Theme.c.surface1 : Theme.c.surface0;
                        border-radius: 4px;

                        cancel-ta := TouchArea {
                            clicked => { cancelled(); }
                        }

                        Text {
                            text: "Cancel";
                            color: Theme.c.subtext0;
                            font-size: 13px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    Rectangle {
                        width: 80px;
                        height: 30px;
                        background: ok-ta.has-hover ? Theme.c.sky : Theme.c.blue;
                        border-radius: 4px;

                        ok-ta := TouchArea {
                            clicked => { confirmed(input.text); }
                        }

                        Text {
                            text: "OK";
                            color: Theme.c.base;
                            font-size: 13px;
                            font-weight: 600;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }
}

// ── Select popup ─────────────────────────────────────

component SelectPopup inherits Rectangle {
    in property <string> title;
    in property <[SelectOption]> options;
    in property <int> selected-index;
    out property <int> result-index: selected-index;
    in property <bool> popup-visible;

    callback accepted(int);
    callback cancelled();

    if popup-visible: Rectangle {
        background: #00000080;
        width: 100%; height: 100%;

        TouchArea {
            clicked => { cancelled(); }
            scroll-event(e) => {
                return accept;
            }
        }

        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: min(500px, parent.width - 40px);
            height: min(parent.height - 80px, 500px);
            background: Theme.c.mantle;
            border-radius: 8px;
            border-color: Theme.c.surface1;
            border-width: 1px;
            clip: true;

            VerticalLayout {
                padding: 16px;
                spacing: 8px;

                Text {
                    text: title;
                    color: Theme.c.blue;
                    font-size: 16px;
                    font-weight: 600;
                    height: 24px;
                }

                ListView {
                    for option[index] in options: Rectangle {
                        height: 32px;
                        background: item-ta.has-hover ? Theme.c.surface1
                                  : index == result-index ? Theme.c.surface0
                                  : transparent;
                        border-radius: 4px;

                        item-ta := TouchArea {
                            clicked => {
                                result-index = index;
                                accepted(index);
                            }
                        }

                        HorizontalLayout {
                            padding-left: 12px;
                            alignment: start;

                            Text {
                                text: index == result-index ? "> " + option.text : "  " + option.text;
                                color: index == result-index ? Theme.c.green : Theme.c.text;
                                font-size: 14px;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }
        }
    }
}

// ── Sidebar step item ────────────────────────────────

component SidebarItem inherits Rectangle {
    in property <string> label;
    in property <int> state; // 0=pending, 1=current, 2=done
    in property <int> step-index;

    callback clicked();

    height: 36px;
    background: state == 1 ? Theme.c.surface0
              : step-ta.has-hover && state == 2 ? Theme.c.surface0
              : transparent;
    border-radius: 4px;

    step-ta := TouchArea {
        mouse-cursor: state == 2 ? pointer : default;
        clicked => {
            if state == 2 || state == 1 {
                root.clicked();
            }
        }
    }

    HorizontalLayout {
        padding-left: 12px;
        spacing: 8px;
        alignment: start;

        Text {
            text: state == 1 ? "\u{25b8}"  // ▸
                : state == 2 ? "\u{25cf}"   // ●
                : "\u{25cb}";               // ○
            color: state == 1 ? Theme.c.blue
                 : state == 2 ? Theme.c.green
                 : Theme.c.overlay0;
            font-size: 14px;
            vertical-alignment: center;
            width: 16px;
        }

        Text {
            text: label;
            color: state == 1 ? Theme.c.blue
                 : state == 2 ? Theme.c.green
                 : Theme.c.overlay0;
            font-size: 14px;
            font-weight: state == 1 ? 600 : 400;
            vertical-alignment: center;
        }
    }
}

// ── Main application ─────────────────────────────────

export component App inherits Window {
    background: Theme.c.base;
    preferred-width: 800px;
    preferred-height: 600px;
    title: "archinstall-zfs";

    // Wizard state
    in property <[StepInfo]> steps;
    in property <int> current-step: 0;
    in property <int> total-steps: 7;

    // Config items model (per-step)
    in property <[ConfigItem]> config-items;

    // Select popup state
    in-out property <bool> select-visible: false;
    in-out property <string> select-title;
    in-out property <[SelectOption]> select-options;
    in-out property <int> select-index;
    in-out property <string> select-key;

    // Text input popup state
    in-out property <bool> text-input-visible: false;
    in-out property <string> text-input-title;
    in-out property <string> text-input-value;
    in-out property <bool> text-input-password: false;
    in-out property <string> text-input-key;

    // Install state: 0=config, 1=installing, 2=done, 3=failed
    in-out property <int> install-state: 0;

    // Log messages
    in property <[LogMessage]> log-messages;

    // Download progress
    in property <[DownloadInfo]> download-items;
    in property <int> download-pct: 0;
    in property <string> download-status: "";
    in property <bool> download-active: false;

    // Status text
    in property <string> status-text;

    // Keyboard-driven focus index (-1 = none)
    in-out property <int> focused-index: -1;

    // Callbacks to Rust
    callback item-activated(string);
    callback select-confirmed(string, int);
    callback text-confirmed(string, string);
    callback toggle-activated(string);
    callback install-requested();
    callback quit-requested();
    callback step-clicked(int);
    callback next-step();
    callback prev-step();
    callback key-nav-down();
    callback key-nav-up();
    callback key-nav-activate();

    // ── Keyboard navigation ─────────────────────────
    if install-state == 0 && !select-visible && !text-input-visible: FocusScope {
        key-pressed(e) => {
            if e.text == Key.DownArrow || e.text == "j" {
                key-nav-down();
                return accept;
            }
            if e.text == Key.UpArrow || e.text == "k" {
                key-nav-up();
                return accept;
            }
            if e.text == Key.Return {
                key-nav-activate();
                return accept;
            }
            if e.text == Key.Tab {
                next-step();
                return accept;
            }
            if e.text == Key.Backtab {
                prev-step();
                return accept;
            }
            if e.text == "q" {
                quit-requested();
                return accept;
            }
            if e.text == "1" { step-clicked(0); return accept; }
            if e.text == "2" { step-clicked(1); return accept; }
            if e.text == "3" { step-clicked(2); return accept; }
            if e.text == "4" { step-clicked(3); return accept; }
            if e.text == "5" { step-clicked(4); return accept; }
            if e.text == "6" { step-clicked(5); return accept; }
            if e.text == "7" { step-clicked(6); return accept; }
            return reject;
        }
    }

    // ── Wizard config screen ─────────────────────────
    if install-state == 0: VerticalLayout {
        padding: 0px;
        spacing: 0px;

        // Title bar
        Rectangle {
            height: 48px;
            background: Theme.c.mantle;

            HorizontalLayout {
                padding-left: 16px;
                padding-right: 16px;

                Text {
                    text: "archinstall-zfs";
                    color: Theme.c.blue;
                    font-size: 22px;
                    font-weight: 700;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }

                Text {
                    text: (current-step + 1) + " / " + total-steps;
                    color: Theme.c.overlay0;
                    font-size: 14px;
                    vertical-alignment: center;
                }
            }
        }

        // Body: sidebar + content
        HorizontalLayout {
            spacing: 0px;

            // Sidebar
            Rectangle {
                width: 140px;
                background: Theme.c.mantle;

                VerticalLayout {
                    padding: 8px;
                    spacing: 2px;
                    alignment: start;

                    for step[index] in steps: SidebarItem {
                        label: step.label;
                        state: step.state;
                        step-index: index;

                        clicked => {
                            step-clicked(index);
                        }
                    }
                }
            }

            // Vertical separator
            Rectangle {
                width: 1px;
                background: Theme.c.surface1;
            }

            // Content area
            VerticalLayout {
                spacing: 0px;

                // Step title
                Rectangle {
                    height: 40px;
                    background: transparent;

                    HorizontalLayout {
                        padding-left: 16px;
                        alignment: start;

                        Text {
                            text: steps.length > 0 && current-step < steps.length
                                ? steps[current-step].label : "";
                            color: Theme.c.mauve;
                            font-size: 18px;
                            font-weight: 600;
                            vertical-alignment: center;
                        }
                    }
                }

                // Config items list
                ScrollView {
                    VerticalLayout {
                        spacing: 2px;
                        padding: 4px;
                        padding-left: 8px;
                        padding-right: 8px;

                        for item[index] in config-items: Rectangle {
                            height: item.item-type == 4 ? 16px
                                  : item.item-type == 7 ? 28px
                                  : 34px;
                            border-radius: 4px;
                            background: (row-ta.has-hover || index == focused-index)
                                && item.item-type != 4
                                && item.item-type != 6
                                && item.item-type != 7
                                ? Theme.c.surface0 : transparent;

                            // Separator
                            if item.item-type == 4: Rectangle {
                                height: 1px;
                                y: 8px;
                                background: Theme.c.surface0;
                            }

                            // Warning line
                            if item.item-type == 7: HorizontalLayout {
                                padding-left: 16px;
                                alignment: start;

                                Text {
                                    text: "\u{26a0} " + item.value;
                                    color: Theme.c.yellow;
                                    font-size: 13px;
                                    vertical-alignment: center;
                                }
                            }

                            row-ta := TouchArea {
                                mouse-cursor: item.item-type == 4 || item.item-type == 6 || item.item-type == 7
                                    ? default : pointer;
                                clicked => {
                                    focused-index = index;
                                    if item.item-type == 5 {
                                        if item.key == "install" { install-requested(); }
                                        if item.key == "quit" { quit-requested(); }
                                    } else if item.item-type == 3 {
                                        toggle-activated(item.key);
                                    } else if item.item-type != 4
                                           && item.item-type != 6
                                           && item.item-type != 7 {
                                        item-activated(item.key);
                                    }
                                }
                            }

                            // Action items
                            if item.item-type == 5: HorizontalLayout {
                                padding-left: 16px;
                                alignment: start;

                                Text {
                                    text: item.label;
                                    color: Theme.c.peach;
                                    font-size: 14px;
                                    font-weight: 600;
                                    vertical-alignment: center;
                                }
                            }

                            // Read-only summary items (review step)
                            if item.item-type == 6: HorizontalLayout {
                                padding-left: 16px;
                                padding-right: 16px;

                                Text {
                                    text: item.label;
                                    color: Theme.c.overlay0;
                                    font-size: 13px;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                }

                                Text {
                                    text: item.value;
                                    color: item.value == "Not set" || item.value == "None" || item.value == "Disabled"
                                        ? Theme.c.overlay0
                                        : Theme.c.green;
                                    font-size: 13px;
                                    vertical-alignment: center;
                                }
                            }

                            // Normal config items (text, select, password, toggle)
                            if item.item-type != 4 && item.item-type != 5
                                && item.item-type != 6 && item.item-type != 7: HorizontalLayout {
                                padding-left: 16px;
                                padding-right: 16px;

                                Text {
                                    text: item.label;
                                    color: Theme.c.subtext1;
                                    font-size: 14px;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                }

                                Text {
                                    text: item.value;
                                    color: item.value == "Not set" || item.value == "None" || item.value == "Disabled"
                                        ? Theme.c.overlay0
                                        : Theme.c.green;
                                    font-size: 14px;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }
                }

                // Footer with navigation buttons
                Rectangle {
                    height: 44px;
                    background: Theme.c.mantle;

                    HorizontalLayout {
                        padding-left: 16px;
                        padding-right: 16px;
                        spacing: 8px;
                        alignment: center;

                        // Back button
                        if current-step > 0: Rectangle {
                            width: 80px;
                            height: 32px;
                            background: back-ta.has-hover ? Theme.c.surface1 : Theme.c.surface0;
                            border-radius: 4px;

                            back-ta := TouchArea {
                                clicked => { prev-step(); }
                            }

                            Text {
                                text: "\u{25c2} Back";
                                color: Theme.c.subtext0;
                                font-size: 13px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }

                        // Status text
                        Text {
                            text: status-text;
                            color: Theme.c.overlay0;
                            font-size: 12px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }

                        // Next button
                        if current-step < total-steps - 1: Rectangle {
                            width: 80px;
                            height: 32px;
                            background: next-ta.has-hover ? Theme.c.sky : Theme.c.blue;
                            border-radius: 4px;

                            next-ta := TouchArea {
                                clicked => { next-step(); }
                            }

                            Text {
                                text: "Next \u{25b8}";
                                color: Theme.c.base;
                                font-size: 13px;
                                font-weight: 600;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }
        }
    }

    // ── Install progress screen ──────────────────────
    if install-state >= 1: VerticalLayout {
        padding: 16px;
        spacing: 8px;

        Rectangle {
            height: 48px;
            background: Theme.c.mantle;
            border-radius: 4px;

            Text {
                text: install-state == 1 ? "Installing..."
                    : install-state == 2 ? "Installation Complete"
                    : "Installation Failed";
                color: install-state == 1 ? Theme.c.blue
                    : install-state == 2 ? Theme.c.green
                    : Theme.c.red;
                font-size: 20px;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        log-view := ListView {
            for msg[index] in log-messages: Rectangle {
                height: msg-text.preferred-height + 4px;

                msg-text := Text {
                    text: msg.text;
                    color: msg.level == 4 ? Theme.c.red
                         : msg.level == 3 ? Theme.c.yellow
                         : msg.level == 2 ? Theme.c.green
                         : msg.level == 1 ? Theme.c.blue
                         : Theme.c.overlay0;
                    font-family: "monospace";
                    font-size: 12px;
                    x: 8px;
                    width: parent.width - 16px;
                    wrap: word-wrap;
                    vertical-alignment: center;
                }
            }
        }

        property <int> scroll-trigger: log-messages.length;
        changed scroll-trigger => {
            log-view.viewport-y = -100000px;
        }

        // ── Download progress panel ─────────────────
        if download-active: Rectangle {
            height: 120px;
            background: Theme.c.mantle;
            border-radius: 4px;
            border-color: Theme.c.surface1;
            border-width: 1px;

            VerticalLayout {
                padding: 12px;
                spacing: 6px;

                // Header: status text
                Text {
                    text: download-status;
                    color: Theme.c.teal;
                    font-size: 13px;
                    font-weight: 600;
                }

                // Overall progress bar
                Rectangle {
                    height: 16px;
                    background: Theme.c.surface0;
                    border-radius: 3px;
                    clip: true;

                    Rectangle {
                        x: 0;
                        y: 0;
                        height: parent.height;
                        width: parent.width * (download-pct / 100);
                        background: Theme.c.teal;
                        border-radius: 3px;
                    }

                    Text {
                        text: download-pct + "%";
                        color: Theme.c.text;
                        font-size: 11px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                // Per-package download lines
                ListView {
                    for dl[index] in download-items: Rectangle {
                        height: 20px;

                        HorizontalLayout {
                            padding-left: 4px;
                            padding-right: 4px;
                            spacing: 8px;

                            Text {
                                text: dl.filename;
                                color: dl.state == 1 ? Theme.c.overlay0
                                     : dl.state == 2 ? Theme.c.green
                                     : Theme.c.text;
                                font-size: 11px;
                                font-family: "monospace";
                                overflow: elide;
                                horizontal-stretch: 1;
                                vertical-alignment: center;
                            }

                            Text {
                                text: dl.state == 1 ? "verifying..."
                                     : dl.state == 2 ? "done"
                                     : dl.pct + "% " + dl.speed;
                                color: dl.state == 2 ? Theme.c.green : Theme.c.overlay0;
                                font-size: 11px;
                                font-family: "monospace";
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }
        }

        if install-state >= 2: Rectangle {
            height: 36px;

            Rectangle {
                background: exit-ta.has-hover ? Theme.c.surface1 : Theme.c.surface0;
                border-radius: 4px;

                exit-ta := TouchArea {
                    clicked => { quit-requested(); }
                }

                Text {
                    text: "Click to exit";
                    color: Theme.c.subtext0;
                    font-size: 14px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }
    }

    // ── Popup overlays ──────────────────────────────────

    SelectPopup {
        title: select-title;
        options: select-options;
        selected-index: select-index;
        popup-visible: select-visible;

        accepted(idx) => {
            select-visible = false;
            select-confirmed(select-key, idx);
        }
        cancelled() => {
            select-visible = false;
        }
    }

    TextInputPopup {
        title: text-input-title;
        input-text: text-input-value;
        is-password: text-input-password;
        popup-visible: text-input-visible;

        confirmed(val) => {
            text-input-visible = false;
            text-confirmed(text-input-key, val);
        }
        cancelled() => {
            text-input-visible = false;
        }
    }
}
