FROM docker.io/archlinux:latest

# Initialize pacman keyring before any upgrade so post-install hooks that
# locally-sign new keys don't fail with "no secret key available to sign with"
# on fresh docker.io/archlinux layers. Then refresh keyring, install archiso,
# and clean up.
RUN pacman-key --init \
    && pacman-key --populate archlinux \
    && pacman -Sy --noconfirm archlinux-keyring \
    && pacman -Syu --noconfirm archiso \
    && pacman -Scc --noconfirm \
    && rm -rf /var/cache/pacman/pkg/*
